<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <title>Synthèse direction — Audit BACS — {{document.client_name}}</title>
  <style>{{{styles}}}</style>
</head>
<body>

{{!-- ═══════════ Page 1 — État de conformité + KPIs ═══════════ --}}
<section class="exec-page">
  <header class="exec-header">
    <img class="exec-logo" src="{{logoDataUrl}}" alt="Buildy" />
    <div class="exec-meta">
      <div class="exec-meta-row">
        <span class="exec-meta-label">Client</span>
        <span class="exec-meta-value">{{document.client_name}}</span>
      </div>
      <div class="exec-meta-row">
        <span class="exec-meta-label">Site</span>
        <span class="exec-meta-value">{{site.name}}</span>
      </div>
      <div class="exec-meta-row">
        <span class="exec-meta-label">Date</span>
        <span class="exec-meta-value">{{exportDate}}</span>
      </div>
      <div class="exec-meta-row">
        <span class="exec-meta-label">Version</span>
        <span class="exec-meta-value mono">{{version}}</span>
      </div>
    </div>
  </header>

  <h1 class="exec-doc-title">Synthèse direction</h1>
  <p class="exec-doc-subtitle">Audit BACS · décret R175 · présentation décideurs</p>

  {{#if bms.overall_compliance}}
  <div class="exec-verdict exec-verdict-{{bms.overall_compliance}}">
    <span class="exec-verdict-icon">{{#if (eq bms.overall_compliance "compliant")}}✓{{else}}{{#if (eq bms.overall_compliance "partial")}}!{{else}}✗{{/if}}{{/if}}</span>
    <div class="exec-verdict-body">
      <span class="exec-verdict-label">État global de conformité</span>
      <span class="exec-verdict-value">{{complianceLabel}}</span>
    </div>
  </div>
  {{/if}}

  <div class="exec-kpi-grid">
    <div class="exec-kpi exec-kpi-blocking">
      <span class="exec-kpi-num">{{actionStats.blocking}}</span>
      <span class="exec-kpi-label">Bloquantes</span>
    </div>
    <div class="exec-kpi exec-kpi-major">
      <span class="exec-kpi-num">{{actionStats.major}}</span>
      <span class="exec-kpi-label">Majeures</span>
    </div>
    <div class="exec-kpi exec-kpi-minor">
      <span class="exec-kpi-num">{{actionStats.minor}}</span>
      <span class="exec-kpi-label">Mineures</span>
    </div>
    <div class="exec-kpi exec-kpi-total">
      <span class="exec-kpi-num">{{actionItemsRaw.length}}</span>
      <span class="exec-kpi-label">Total</span>
    </div>
  </div>

  {{#if applicabilityLabel}}
  <div class="exec-applicability">
    <span class="exec-applicability-label">Échéance R175-2</span>
    <span class="exec-applicability-value">{{applicabilityLabel}}</span>
    {{#if document.bacs_total_power_kw}}
    <span class="exec-applicability-power">Puissance cumulée chauffage + clim : <strong>{{document.bacs_total_power_kw}} kW</strong></span>
    {{/if}}
  </div>
  {{/if}}

  {{#if synthesisHtml}}
  <div class="exec-synthesis">
    <h3 class="exec-section-title">Note de synthèse</h3>
    <div class="exec-synthesis-body">{{{synthesisHtml}}}</div>
  </div>
  {{/if}}
</section>

{{!-- ═══════════ Page 2 — Top 5 actions + charts + contact ═══════════ --}}
<section class="exec-page">
  <h3 class="exec-section-title">Actions prioritaires</h3>
  {{#if topActions.length}}
  <div class="exec-actions">
    {{#each topActions}}
    <div class="exec-action exec-action-{{severity}}">
      <span class="exec-action-num">{{display_number}}</span>
      <span class="exec-action-sev exec-action-sev-{{severity}}">
        {{#if (eq severity "blocking")}}Bloquante{{else}}{{#if (eq severity "major")}}Majeure{{else}}Mineure{{/if}}{{/if}}
      </span>
      <div class="exec-action-body">
        <div class="exec-action-title">{{title}}</div>
        <div class="exec-action-meta">
          {{#if r175_article}}<span class="mono">{{r175_article}}</span>{{/if}}
          {{#if zone_name}}<span>· 📍 {{zone_name}}</span>{{/if}}
        </div>
      </div>
    </div>
    {{/each}}
  </div>
  {{#if (gt actionItemsRaw.length 5)}}
  <p class="exec-actions-footer">+ {{actionItemsRaw.length}} actions au total — détail complet dans le rapport long.</p>
  {{/if}}
  {{else}}
  <div class="exec-no-actions">
    <span class="exec-no-actions-icon">✓</span>
    <div>
      <strong>Aucune action corrective.</strong>
      <p>Le site est conforme au décret BACS dans son périmètre actuel.</p>
    </div>
  </div>
  {{/if}}

  {{#if (or sevDonutDataUrl radarComplianceDataUrl)}}
  <div class="exec-charts-row">
    {{#if sevDonutDataUrl}}
    <div class="exec-chart-block">
      <h4 class="exec-chart-title">Répartition par sévérité</h4>
      <img src="{{sevDonutDataUrl}}" alt="Répartition par sévérité" />
    </div>
    {{/if}}
    {{#if radarComplianceDataUrl}}
    <div class="exec-chart-block">
      <h4 class="exec-chart-title">Score de conformité par exigence R175</h4>
      <img src="{{radarComplianceDataUrl}}" alt="Score de conformité R175" />
    </div>
    {{/if}}
  </div>
  {{/if}}

  <footer class="exec-footer">
    <div class="exec-footer-block">
      <span class="exec-footer-label">Mise en conformité</span>
      <p>L'équipe commerciale Buildy se tient à votre disposition pour établir un devis chiffré sur la base du rapport long.</p>
    </div>
    <div class="exec-footer-meta">
      <span>Auditeur : <strong>{{authorName}}</strong></span>
      <span>Document confidentiel — {{exportDate}}</span>
    </div>
  </footer>
</section>

</body>
</html>
