<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<title>Synthèse — {{af.client_name}} — {{af.project_name}}</title>
<style>{{{styles}}}</style>
</head>
<body>

{{!-- ═══════════════════ PAGE 1 — Bilan & verdict ═══════════════════ --}}
<section class="page">
  <header class="page-header">
    <div class="page-header-left">
      <img class="page-logo" src="{{logoDataUrl}}" alt="Buildy" />
      <div>
        <p class="page-doctype">Synthèse de l'analyse fonctionnelle</p>
        <h1 class="page-title">{{af.client_name}} — {{af.project_name}}</h1>
        {{#if af.site_address}}<p class="page-subtitle">{{af.site_address}}</p>{{/if}}
      </div>
    </div>
    <div class="page-header-right">
      <p class="page-meta"><span class="meta-label">Version</span> <span class="version-tag">{{version}}</span></p>
      <p class="page-meta"><span class="meta-label">Date</span> {{exportDate}}</p>
      <p class="page-meta"><span class="meta-label">Auteur</span> {{authorName}}</p>
    </div>
  </header>

  <h2 class="section-h">1. Bilan du projet</h2>

  <div class="kpi-grid">
    <div class="kpi-card">
      <p class="kpi-value">{{kpis.systemsCovered}}<span class="kpi-value-sub">/{{kpis.systemsCatalog}}</span></p>
      <p class="kpi-label">Systèmes supervisés</p>
      <p class="kpi-hint">catégories d'équipement avec instances</p>
    </div>
    <div class="kpi-card">
      <p class="kpi-value">{{kpis.instancesTotal}}</p>
      <p class="kpi-label">Instances déclarées</p>
      <p class="kpi-hint">références d'équipements réels sur site</p>
    </div>
    <div class="kpi-card">
      <p class="kpi-value">{{kpis.pointsTotal}}</p>
      <p class="kpi-label">Points contractuels</p>
      <p class="kpi-hint">total points × instances</p>
    </div>
    <div class="kpi-card kpi-level kpi-level-{{kpis.verdict.kind}}">
      <p class="kpi-value">{{#if kpis.requiredLevelLabel}}{{kpis.requiredLevelLabel}}{{else}}—{{/if}}</p>
      <p class="kpi-label">Niveau Buildy requis</p>
      <p class="kpi-hint">{{#if kpis.contractLevelLabel}}contrat actuel : {{kpis.contractLevelLabel}}{{else}}contrat à définir{{/if}}</p>
    </div>
  </div>

  <div class="verdict verdict-{{kpis.verdict.kind}}">
    <p class="verdict-title">
      {{#if (eq kpis.verdict.kind 'ok')}}✓ Couverture cohérente avec le contrat{{/if}}
      {{#if (eq kpis.verdict.kind 'over')}}ⓘ Marge contractuelle disponible{{/if}}
      {{#if (eq kpis.verdict.kind 'shortfall')}}⚠ Niveau de contrat insuffisant{{/if}}
      {{#if (eq kpis.verdict.kind 'no-contract')}}ⓘ Niveau de contrat à arbitrer{{/if}}
      {{#if (eq kpis.verdict.kind 'none')}}ⓘ Aucun calcul possible{{/if}}
    </p>
    <p class="verdict-text">{{kpis.verdict.text}}</p>
  </div>

  {{!-- Barre de couverture fonctionnelle Buildy --}}
  <div class="coverage-block">
    <div class="coverage-head">
      <h3 class="coverage-title">Couverture fonctionnelle de la solution Buildy</h3>
      <p class="coverage-summary">
        <strong>{{kpis.coverage.active}}</strong> sous-section{{#if (gt kpis.coverage.active 1)}}s{{/if}} active{{#if (gt kpis.coverage.active 1)}}s{{/if}}
        sur {{kpis.coverage.total}} ({{kpis.coverage.activePercent}}%)
        {{#if kpis.coverage.optedOut}} · <span class="coverage-tag tag-opt">{{kpis.coverage.optedOut}} écartée{{#if (gt kpis.coverage.optedOut 1)}}s{{/if}} MOA</span>{{/if}}
        {{#if kpis.coverage.excluded}} · <span class="coverage-tag tag-exc">{{kpis.coverage.excluded}} exclue{{#if (gt kpis.coverage.excluded 1)}}s{{/if}}</span>{{/if}}
      </p>
    </div>
    <div class="coverage-bar">
      <div class="coverage-bar-active" style="width: {{kpis.coverage.activePercent}}%"></div>
    </div>
    <p class="coverage-note">Détail page 3.</p>
  </div>

  {{#if optedOutList.length}}
  <div class="opted-block">
    <h3 class="opted-title">Fonctionnalités écartées par la maîtrise d'ouvrage ({{optedOutList.length}})</h3>
    <p class="opted-intro">Ces fonctionnalités ne seront pas disponibles à la livraison. Pour les activer, un contrat adapté devra être conclu entre Buildy et l'exploitant.</p>
    <ul class="opted-list">
      {{#each optedOutList}}
      <li><strong>§{{number}} {{title}}</strong> <span class="opted-contract">→ contrat {{requiredContract}} requis</span></li>
      {{/each}}
    </ul>
  </div>
  {{/if}}
</section>

{{!-- ═══════════════════ PAGE 2 — Conformité BACS ═══════════════════ --}}
<section class="page">
  <header class="page-header">
    <div class="page-header-left">
      <img class="page-logo" src="{{logoDataUrl}}" alt="Buildy" />
      <div>
        <p class="page-doctype">Synthèse — {{af.client_name}} {{af.project_name}}</p>
        <h1 class="page-title">2. Conformité au décret BACS (R175-3)</h1>
      </div>
    </div>
    <div class="page-header-right">
      <p class="page-meta"><span class="meta-label">Version</span> <span class="version-tag">{{version}}</span></p>
    </div>
  </header>

  <p class="section-intro">L'article R175-3 du Code de la construction et de l'habitation définit les <strong>4 exigences fonctionnelles</strong> auxquelles doit répondre tout système d'automatisation et de contrôle des bâtiments (BACS). Ce tableau récapitule la couverture de chaque exigence par les fonctions Buildy décrites dans cette analyse fonctionnelle, et liste les systèmes du projet réellement concernés.</p>

  <table class="bacs-table">
    <thead>
      <tr>
        <th class="bacs-col-art">Article</th>
        <th class="bacs-col-text">Exigence du décret</th>
        <th class="bacs-col-resp">Réponse Buildy</th>
        <th class="bacs-col-sec">Sections AF qui couvrent</th>
        <th class="bacs-col-sys">Systèmes du projet concernés</th>
        <th class="bacs-col-sta">Statut</th>
      </tr>
    </thead>
    <tbody>
      {{#each bacsConformity}}
      <tr>
        <td class="bacs-col-art">
          <span class="bacs-code">R175-3 {{code}}</span>
          <p class="bacs-title">{{title}}</p>
        </td>
        <td class="bacs-col-text">{{text}}</td>
        <td class="bacs-col-resp">{{buildyAnswer}}</td>
        <td class="bacs-col-sec">
          {{#if sections.length}}
          <ul class="bacs-sec-list">
            {{#each sections}}
            <li class="{{#unless live}}sec-inactive{{/unless}}">
              <code>§{{number}}</code> {{title}}
              {{#if opted_out}}<span class="sec-tag tag-opted">écartée</span>{{/if}}
              {{#if excluded}}<span class="sec-tag tag-excluded">exclue</span>{{/if}}
            </li>
            {{/each}}
          </ul>
          {{else}}—{{/if}}
        </td>
        <td class="bacs-col-sys">
          {{#if systemsConcerned.length}}
          <ul class="bacs-sec-list">
            {{#each systemsConcerned}}
            <li><code>§{{number}}</code> {{title}} <span class="sys-qty">×{{instances}}</span></li>
            {{/each}}
          </ul>
          {{else}}<span class="muted-italic">Aucun système du projet concerné</span>{{/if}}
        </td>
        <td class="bacs-col-sta">
          <span class="bacs-status status-{{status}}">{{statusLabel}}</span>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <p class="legal-note">
    <strong>R175-5-1</strong> — Cette analyse fonctionnelle constitue le document examiné lors de l'inspection
    périodique obligatoire du système d'automatisation et de contrôle. Elle doit être conservée par le propriétaire pendant 10 ans.
  </p>
</section>

{{!-- ═══════════════════ PAGE 3 — Fonctionnalités Buildy par chapitre ═══════════════════ --}}
<section class="page">
  <header class="page-header">
    <div class="page-header-left">
      <img class="page-logo" src="{{logoDataUrl}}" alt="Buildy" />
      <div>
        <p class="page-doctype">Synthèse — {{af.client_name}} {{af.project_name}}</p>
        <h1 class="page-title">3. Fonctionnalités Buildy activées</h1>
      </div>
    </div>
    <div class="page-header-right">
      <p class="page-meta"><span class="meta-label">Version</span> <span class="version-tag">{{version}}</span></p>
    </div>
  </header>

  <p class="section-intro">Vue par grand domaine fonctionnel (chapitres 3 à 11 de l'AF). Chaque sous-section est marquée selon son statut : <span class="dot dot-active"></span> active dans le scope, <span class="dot dot-opt"></span> écartée par la maîtrise d'ouvrage, <span class="dot dot-exc"></span> exclue de l'export.</p>

  <div class="features-grid">
    {{#each featuresByChapter}}
    <div class="feature-chapter">
      <div class="feature-chapter-head">
        <h3 class="feature-chapter-title">{{title}}</h3>
        <span class="feature-chapter-counter">
          <strong>{{counts.active}}</strong>/{{counts.total}} active{{#if (gt counts.active 1)}}s{{/if}}
          {{#if counts.optedOut}}· <span class="opt-counter">{{counts.optedOut}} écartée{{#if (gt counts.optedOut 1)}}s{{/if}}</span>{{/if}}
          {{#if counts.excluded}}· <span class="exc-counter">{{counts.excluded}} exclue{{#if (gt counts.excluded 1)}}s{{/if}}</span>{{/if}}
        </span>
      </div>
      <ul class="feature-list">
        {{#each items}}
        <li class="feature-item feature-{{statusKey}}">
          <span class="feature-icon">
            {{#if (eq statusKey 'active')}}✓{{/if}}
            {{#if (eq statusKey 'opted-out')}}🚫{{/if}}
            {{#if (eq statusKey 'excluded')}}⊘{{/if}}
          </span>
          <div class="feature-body">
            <p class="feature-head-line">
              <code class="feature-num">§{{number}}</code>
              <span class="feature-title">{{title}}</span>
              {{#if serviceLevel}}<span class="level-pill lvl-{{levelClass}}">{{serviceLevel}}</span>{{/if}}
            </p>
            {{#if excerpt}}<p class="feature-desc">{{excerpt}}</p>{{/if}}
            {{#if requiredContract}}<p class="feature-contract">Contrat <strong>{{requiredContract}}</strong> requis pour activer cette fonctionnalité</p>{{/if}}
          </div>
        </li>
        {{/each}}
      </ul>
    </div>
    {{/each}}
  </div>
</section>

{{!-- ═══════════════════ PAGE 4 — Périmètre supervisé ═══════════════════ --}}
<section class="page">
  <header class="page-header">
    <div class="page-header-left">
      <img class="page-logo" src="{{logoDataUrl}}" alt="Buildy" />
      <div>
        <p class="page-doctype">Synthèse — {{af.client_name}} {{af.project_name}}</p>
        <h1 class="page-title">4. Périmètre des équipements supervisés</h1>
      </div>
    </div>
    <div class="page-header-right">
      <p class="page-meta"><span class="meta-label">Version</span> <span class="version-tag">{{version}}</span></p>
    </div>
  </header>

  <p class="section-intro">
    Liste des catégories d'équipement <strong>réellement présentes dans le scope du chantier</strong> :
    soit instanciées (au moins une référence sur site), soit explicitement écartées par la maîtrise d'ouvrage.
  </p>

  <p class="bacs-legend">
    <strong>Légende R175-1</strong> :
    <span class="legend-item"><span class="m-bacs-tag">§1</span> chauffage</span>
    <span class="legend-item"><span class="m-bacs-tag">§2</span> climatisation</span>
    <span class="legend-item"><span class="m-bacs-tag">§3</span> ventilation</span>
    <span class="legend-item"><span class="m-bacs-tag">§4</span> système technique de bâtiment (ECS, éclairage intégré, production électricité)</span>
  </p>

  <table class="matrix-table">
    <thead>
      <tr>
        <th class="m-cat">Système</th>
        <th class="m-bacs">Statut au sens BACS R175-1</th>
        <th class="m-status">Statut projet</th>
        <th class="m-num">Instances</th>
        <th class="m-num">Points / inst.</th>
        <th class="m-num">Total points</th>
      </tr>
    </thead>
    <tbody>
      {{#each systemsMatrix}}
      <tr class="status-row-{{statusClass}}">
        <td class="m-cat">
          <span class="m-num-prefix">§{{number}}</span> {{title}}
        </td>
        <td class="m-bacs">
          {{#if bacs}}
            <span class="m-bacs-tag">{{bacs}}</span>
          {{else if isMetering}}
            <span class="m-bacs-tag-soft">Hors périmètre direct · contribue R175-3 §1</span>
          {{else}}
            <span class="muted">Hors périmètre BACS</span>
          {{/if}}
        </td>
        <td class="m-status"><span class="status-pill status-{{statusClass}}">{{status}}</span></td>
        <td class="m-num">{{#if instances}}<strong>{{instances}}</strong>{{else}}<span class="muted">0</span>{{/if}}</td>
        <td class="m-num">{{pointsPerInstance}}</td>
        <td class="m-num">{{#if totalPoints}}<strong>{{totalPoints}}</strong>{{else}}<span class="muted">—</span>{{/if}}</td>
      </tr>
      {{/each}}
      {{#unless systemsMatrix.length}}
      <tr><td colspan="6" class="empty-row">Aucun équipement instancié ni écarté à ce jour.</td></tr>
      {{/unless}}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="3">Total projet</td>
        <td class="m-num"><strong>{{totalsMatrix.instances}}</strong></td>
        <td class="m-num">—</td>
        <td class="m-num"><strong>{{totalsMatrix.points}}</strong></td>
      </tr>
    </tfoot>
  </table>

  {{#if offCatalogCount}}
  <p class="legal-note">
    <strong>{{offCatalogCount}} catégorie{{#if (gt offCatalogCount 1)}}s{{/if}} d'équipement</strong> du catalogue Buildy
    {{#if (gt offCatalogCount 1)}}existent{{else}}existe{{/if}} mais
    {{#if (gt offCatalogCount 1)}}ne sont pas incluses{{else}}n'est pas incluse{{/if}} dans ce projet
    (par exemple : éclairage extérieur, occultation, process industriel, équipements génériques).
    Voir le chapitre 2 de l'analyse fonctionnelle complète pour le détail.
  </p>
  {{/if}}
</section>

</body>
</html>
