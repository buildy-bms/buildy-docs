# ─── Server ────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=3100
LOG_LEVEL=info
PUBLIC_URL=http://localhost:5173

# ─── Auth ──────────────────────────────────────────────────
# Generer : openssl rand -hex 32
JWT_SECRET=change-me-in-prod-openssl-rand-hex-32

# Mode dev rapide : injecte un user fictif sans PocketID. INACTIF en prod.
DEV_BYPASS_AUTH=1
DEV_BYPASS_EMAIL=dev@buildy.fr
DEV_BYPASS_NAME=Dev User

# ─── PocketID OIDC ─────────────────────────────────────────
# A activer en prod (DEV_BYPASS_AUTH doit etre 0).
OIDC_ENABLED=false
OIDC_ISSUER=https://id.buildy.fr
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://buildy-af.buildy.wan/api/auth/oidc/callback

# ─── CORS (origines autorisees, separer par virgule) ───────
CORS_ORIGINS=http://localhost:5173,http://localhost:3100

# ─── HTTPS (optionnel — pour acces NetBird) ────────────────
HTTPS_ENABLED=false
# HTTPS_CERT_PATH=/path/to/server.crt
# HTTPS_KEY_PATH=/path/to/server.key

# ─── Storage ───────────────────────────────────────────────
# Laisser commente pour utiliser les chemins absolus par defaut
# (resolu par rapport a backend-node/src/, donc projet/data/...).
# Definir uniquement si tu veux un emplacement custom (utiliser un chemin ABSOLU).
# DATABASE_PATH=/opt/buildy-af/data/buildy_af.db
# ATTACHMENTS_DIR=/opt/buildy-af/data/attachments
# EXPORTS_DIR=/opt/buildy-af/data/exports

# ─── Anthropic (assistant Claude + transcript Plaud B3) ────
# Requis pour : synthese audit, alternatives, suggestions transcript.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Synchronisation sites avec Fleet Manager ──────────────
BUILDY_SITES_SYNC_TOKEN=
FM_SYNC_URL=https://fleet-manager.buildy.wan/api/sites/sync
