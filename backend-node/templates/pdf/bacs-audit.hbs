<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<title>{{#if isBacs}}Audit BACS{{else}}Audit GTB{{/if}} — {{document.client_name}} — {{document.project_name}}</title>
<style>{{{styles}}}</style>
</head>
<body>

{{!-- ═══════════ Page de garde ═══════════ --}}
<section class="cover">
  <img class="cover-logo" src="{{logoDataUrl}}" alt="Buildy" />
  <p class="cover-doc-type">{{#if isBacs}}Audit BACS — Décret R175{{else}}Audit GTB (Classique) — Préparation devis Buildy{{/if}}</p>
  <h1 class="cover-title">{{document.project_name}}</h1>
  <p class="cover-client">{{document.client_name}}</p>
  {{#if site.name}}<p class="cover-project">Site : {{site.name}}</p>{{/if}}
  {{#if site.address}}<p class="cover-address">{{site.address}}</p>{{/if}}

  {{#if isBacs}}{{#if applicabilityLabel}}
  <div class="cover-deadline-block">
    <p class="cover-deadline-label">Applicabilité R175-2</p>
    <p class="cover-deadline-value">{{applicabilityLabel}}</p>
    {{#if document.bacs_total_power_kw}}
    <p class="cover-deadline-detail">
      Puissance nominale utile cumulée chauffage + climatisation : <strong>{{document.bacs_total_power_kw}} kW</strong>
    </p>
    {{/if}}
  </div>
  {{/if}}{{/if}}

  <div class="cover-meta">
    <div class="cover-meta-row">
      <span class="cover-meta-label">Date d'audit</span>
      <span class="cover-meta-value">{{exportDate}}</span>
    </div>
    <div class="cover-meta-row">
      <span class="cover-meta-label">Auteur</span>
      <span class="cover-meta-value">{{authorName}}</span>
    </div>
    <div class="cover-meta-row">
      <span class="cover-meta-label">Version</span>
      <span class="cover-meta-value"><span class="cover-version-tag">{{version}}</span></span>
    </div>
    <div class="cover-meta-row">
      <span class="cover-meta-label">Type de document</span>
      <span class="cover-meta-value">{{#if isBacs}}Audit de conformité au décret BACS{{else}}Audit GTB classique (préparation devis Buildy){{/if}}</span>
    </div>
  </div>
</section>

{{!-- ═══════════ Table des matieres ═══════════ --}}
<section class="toc">
  <h1 class="toc-title">Sommaire</h1>
  <ol class="toc-list">
    {{#if synthesisHtml}}
    <li data-toc-link="synthesis"><span class="toc-label">Note de synthèse</span><span class="toc-dots"></span><span class="toc-page">—</span></li>
    {{/if}}
    {{#if isBacs}}
    <li data-toc-link="conformity"><span class="toc-label">Synthèse de conformité</span><span class="toc-dots"></span><span class="toc-page">—</span></li>
    {{/if}}
    <li data-toc-link="identification"><span class="toc-label">1. Identification du site</span><span class="toc-dots"></span><span class="toc-page">—</span></li>
    <li data-toc-link="zones"><span class="toc-label">2. Zones fonctionnelles{{#if isBacs}} (R175-1 §6){{/if}}</span><span class="toc-dots"></span><span class="toc-page">—</span></li>
    <li data-toc-link="systems"><span class="toc-label">3. Systèmes techniques par zone{{#if isBacs}} (R175-1 §4){{/if}}</span><span class="toc-dots"></span><span class="toc-page">—</span></li>
    <li data-toc-link="meters"><span class="toc-label">4. Compteurs et mesurage{{#if isBacs}} (R175-3 §1){{/if}}</span><span class="toc-dots"></span><span class="toc-page">—</span></li>
    {{#if isBacs}}
    <li data-toc-link="thermal"><span class="toc-label">5. Régulation thermique automatique (R175-6)</span><span class="toc-dots"></span><span class="toc-page">—</span></li>
    {{/if}}
    <li data-toc-link="bms"><span class="toc-label">{{#if isBacs}}{{#if synthesisHtml}}{{!---}}{{/if}}6. Solution GTB / GTC (R175-3, R175-4, R175-5){{else}}5. Solution de supervision en place{{/if}}</span><span class="toc-dots"></span><span class="toc-page">—</span></li>
    {{#if isBacs}}
    <li data-toc-link="plan"><span class="toc-label">7. Plan de mise en conformité</span><span class="toc-dots"></span><span class="toc-page">—</span></li>
    {{/if}}
  </ol>
</section>

<div class="sections">

{{#if synthesisHtml}}
{{!-- ═══════════ Synthèse executive ═══════════ --}}
<h1 class="chapter" data-toc-anchor="synthesis">{{{faIcon "sparkles" "#7c3aed" "22"}}} Note de synthèse</h1>
<div class="synthesis-block">{{{synthesisHtml}}}</div>
{{/if}}

{{#if isBacs}}
{{!-- ═══════════ Synthèse de conformité (anciennement chapitre 7, remontée au début) ═══════════ --}}
<h1 class="chapter" data-toc-anchor="conformity">{{{faIcon "shield" "#10b981" "22"}}} Synthèse de conformité</h1>
{{#if bms.overall_compliance}}
<p>État global de la conformité au décret BACS : <span class="status status-{{bms.overall_compliance}}">{{complianceLabel}}</span></p>
{{/if}}

<div class="charts-row" style="display: flex; gap: 12mm; align-items: flex-start; margin: 4mm 0;">
  <div style="flex: 0 0 auto;">
    <table style="margin: 0;">
      <thead><tr><th>Sévérité</th><th>Actions</th></tr></thead>
      <tbody>
        <tr><td><span class="sev sev-blocking">Bloquantes</span></td><td><strong>{{actionStats.blocking}}</strong></td></tr>
        <tr><td><span class="sev sev-major">Majeures</span></td><td><strong>{{actionStats.major}}</strong></td></tr>
        <tr><td><span class="sev sev-minor">Mineures</span></td><td><strong>{{actionStats.minor}}</strong></td></tr>
      </tbody>
    </table>
  </div>
  {{#if sevDonutDataUrl}}
  <div style="flex: 0 0 auto; max-width: 80mm;">
    <img src="{{sevDonutDataUrl}}" alt="Répartition des actions par sévérité" style="width: 100%; max-width: 80mm;" />
  </div>
  {{/if}}
</div>

{{#if radarComplianceDataUrl}}
<p style="margin-top: 6mm; font-weight: 600; color: #4b5563;">Score de conformité par exigence R175</p>
<div style="text-align: center; margin: 2mm 0;">
  <img src="{{radarComplianceDataUrl}}" alt="Radar de conformité R175" style="max-width: 130mm;" />
</div>
<p class="muted" style="font-size: 9pt;">Score 0-100 par axe : 100 = aucune action corrective ouverte. Pénalisations : -40 par bloquante, -20 par majeure, -10 par mineure.</p>
{{/if}}

<p class="muted">Détail des actions et préconisations Buildy : voir chapitre 7 « Plan de mise en conformité ».</p>
{{/if}}

{{!-- ═══════════ Chapitre 1 — Identification site ═══════════ --}}
<h1 class="chapter" data-toc-anchor="identification">{{{faIcon "building" "#4f46e5" "22"}}} 1. Identification du site</h1>
<table class="meta-table">
  <tr><th>Site</th><td>{{site.name}}</td></tr>
  <tr><th>Client</th><td>{{document.client_name}}</td></tr>
  <tr><th>Adresse</th><td>{{site.address}}</td></tr>
  {{#if isBacs}}
  {{#if document.bacs_total_power_kw}}
  <tr><th>Puissance cumulée<br>chauffage + clim</th><td><strong>{{document.bacs_total_power_kw}} kW</strong></td></tr>
  {{/if}}
  {{#if document.bacs_district_heating_substation_kw}}
  <tr>
    <th>Puissance station d'échange</th>
    <td>
      <strong>{{document.bacs_district_heating_substation_kw}} kW</strong>
      <span class="muted">— référence R175-2 (bâtiment raccordé à un réseau urbain)</span>
    </td>
  </tr>
  {{/if}}
  {{#if document.bacs_building_permit_date}}
  <tr><th>Date de permis de construire</th><td>{{document.bacs_building_permit_date}}</td></tr>
  {{/if}}
  {{#if applicabilityLabel}}
  <tr><th>Applicabilité BACS (R175-2)</th><td><strong>{{applicabilityLabel}}</strong></td></tr>
  {{/if}}
  <tr>
    <th>AF de la GTB existante</th>
    <td>
      {{#if (eq document.audit_existing_af_status "absent")}}
        <span style="color:#9a3412">Aucun document d'AF disponible pour la GTB existante.</span>
      {{else}}
        Document fourni par le propriétaire ou son exploitant.
      {{/if}}
    </td>
  </tr>
  {{/if}}
</table>

{{#if isBacs}}{{#if heatingCoolingBreakdown.length}}
<h3>Détail du calcul automatique de la puissance</h3>
<p class="muted" style="margin-bottom:2mm">
  La puissance cumulée chauffage + climatisation est obtenue en additionnant
  les puissances nominales utiles des équipements saisis dans les catégories
  <strong>chauffage</strong> et <strong>climatisation</strong> (chapitre 3).
</p>
<table>
  <thead>
    <tr><th>Équipement</th><th>Marque / référence</th><th>Catégorie</th><th>Zone</th><th>Puissance</th></tr>
  </thead>
  <tbody>
    {{#each heatingCoolingBreakdown}}
      <tr>
        <td>{{name}}</td>
        <td>{{brand}}{{#if model_reference}} / {{model_reference}}{{/if}}</td>
        <td>{{categoryLabel}}</td>
        <td>{{zone_name}}</td>
        <td><strong>{{power_kw}} kW</strong></td>
      </tr>
    {{/each}}
    <tr class="total-row">
      <td colspan="4" style="text-align:right"><strong>Total chauffage + climatisation</strong></td>
      <td><strong>{{heatingCoolingTotal}} kW</strong></td>
    </tr>
  </tbody>
</table>
{{/if}}{{/if}}

{{#if barUsagePowerDataUrl}}
<h3>Répartition de la puissance par usage</h3>
<div style="text-align: center; margin: 2mm 0;">
  <img src="{{barUsagePowerDataUrl}}" alt="Puissance par usage GTB" style="max-width: 140mm;" />
</div>
{{/if}}

{{!-- ═══════════ Chapitre 2 — Zones fonctionnelles ═══════════ --}}
<h1 class="chapter" data-toc-anchor="zones">{{{faIcon "map-pin" "#4f46e5" "22"}}} 2. Zones fonctionnelles{{#if isBacs}} (R175-1 §6){{/if}}</h1>
{{#if zones.length}}
<table>
  <thead><tr><th>Zone</th><th>Nature</th><th>Surface (m²)</th></tr></thead>
  <tbody>
    {{#each zones}}
      <tr><td>{{name}}</td><td>{{nature}}</td><td>{{surface_m2}}</td></tr>
    {{/each}}
  </tbody>
</table>
{{#each zones}}
  {{#if (or notes_html notes photos.length)}}
    <div class="entity-block">
      <h3>{{name}}</h3>
      {{#if notes_html}}<div class="rich-notes">{{{notes_html}}}</div>
      {{else}}{{#if notes}}<p>{{notes}}</p>{{/if}}{{/if}}
      {{#if photos.length}}
        <div class="photo-grid">
          {{#each photos}}<img src="{{dataUrl}}" alt="" />{{/each}}
        </div>
      {{/if}}
    </div>
  {{/if}}
{{/each}}
{{else}}
<p class="muted">Aucune zone définie.</p>
{{/if}}

{{!-- ═══════════ Chapitre 3 — Systèmes techniques ═══════════ --}}
<h1 class="chapter" data-toc-anchor="systems">{{{faIcon "wrench" "#4f46e5" "22"}}} 3. Systèmes techniques par zone{{#if isBacs}} (R175-1 §4){{/if}}</h1>
{{#each systemsByZone}}
<h2>{{zone_name}} <span class="muted">({{zone_nature}})</span></h2>
{{#each items}}
  {{#if present}}
    <h3>{{{categoryIcon system_category "18"}}}{{categoryLabel}}{{#if total_power_kw}} <span class="muted">— {{total_power_kw}} kW total ({{device_count}} équipement{{#if device_count}}{{#unless (eq device_count 1)}}s{{/unless}}{{/if}})</span>{{/if}}</h3>
    {{#if devices.length}}
      <table class="device-table">
        <thead>
          <tr>
            <th style="width:24%">Équipement</th>
            <th style="width:20%">Marque / réf.</th>
            <th style="width:9%">Énergie</th>
            <th style="width:8%">Puiss.</th>
            <th style="width:11%">Nature</th>
            <th style="width:14%">Communication</th>
            <th style="width:14%">Localisation</th>
          </tr>
        </thead>
        <tbody>
          {{#each devices}}
            <tr {{#if out_of_service}}style="opacity:0.5"{{/if}}>
              <td>
                <strong>{{name}}</strong>
                {{#if out_of_service}}<span style="color:#b91c1c;font-weight:600"> · HS</span>{{/if}}
              </td>
              <td>{{brand}}{{#if model_reference}} <span class="muted">/ {{model_reference}}</span>{{/if}}</td>
              <td>{{energyLabel}}</td>
              <td>{{power_kw}}{{#if power_kw}} kW{{/if}}</td>
              <td>{{roleLabel}}</td>
              <td>{{commLabel}}</td>
              <td>{{location}}</td>
            </tr>
            <tr class="r175-3-row" {{#if out_of_service}}style="opacity:0.5"{{/if}}>
              <td colspan="7" style="padding-top:0.5mm;padding-bottom:2mm;font-size:7.5pt;border-bottom:1px solid #f3f4f6">
                <span class="r175-3-label">R175-3 :</span>
                <span class="r175-3-pill {{#if meets_r175_3_p3}}r175-3-ok{{else}}r175-3-ko{{/if}}">
                  {{#if meets_r175_3_p3}}✓{{else}}✗{{/if}} §3 Interopérable
                </span>
                <span class="r175-3-pill {{#if meets_r175_3_p4}}r175-3-ok{{else}}r175-3-ko{{/if}}">
                  {{#if meets_r175_3_p4}}✓{{else}}✗{{/if}} §4 Arrêt manuel
                </span>
                <span class="r175-3-pill {{#if meets_r175_3_p4_autonomous}}r175-3-ok{{else}}r175-3-ko{{/if}}">
                  {{#if meets_r175_3_p4_autonomous}}✓{{else}}✗{{/if}} §4 Reprise autonome
                </span>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p class="muted">Système marqué présent mais aucun équipement détaillé n'a été saisi.</p>
    {{/if}}
    {{#if notes_html}}
      <div class="rich-notes">{{{notes_html}}}</div>
    {{else}}{{#if notes}}<p class="muted"><em>Notes :</em> {{notes}}</p>{{/if}}{{/if}}
    {{#if photos.length}}
      <div class="photo-grid">
        {{#each photos}}<img src="{{dataUrl}}" alt="" />{{/each}}
      </div>
    {{/if}}
    {{#each devices}}
      {{#if (or notes_html photos.length)}}
        <div class="device-notes">
          <strong class="muted">{{name}}{{#if brand}} — {{brand}}{{/if}}{{#if model_reference}} {{model_reference}}{{/if}}</strong>
          {{#if notes_html}}<div class="rich-notes">{{{notes_html}}}</div>{{/if}}
          {{#if photos.length}}
            <div class="photo-grid">
              {{#each photos}}<img src="{{dataUrl}}" alt="" />{{/each}}
            </div>
          {{/if}}
        </div>
      {{/if}}
    {{/each}}
  {{else}}
    {{#if not_concerned}}
      <h3 class="muted">{{negativeLabel}}</h3>
    {{else}}
      <h3 class="muted">{{categoryLabel}} — non présent</h3>
    {{/if}}
  {{/if}}
{{/each}}
{{/each}}

{{!-- ═══════════ Chapitre 4 — Compteurs ═══════════ --}}
<h1 class="chapter" data-toc-anchor="meters">{{{faIcon "gauge" "#10b981" "22"}}} 4. Compteurs et mesurage{{#if isBacs}} (R175-3 §1){{/if}}</h1>
{{#if meters.length}}
<table>
  <thead>
    <tr>
      <th>Zone</th><th>Usage</th><th>Type</th>
      <th>Requis</th><th>Présent</th><th>Communicant</th><th>Intégré GTB</th><th>HS</th>
    </tr>
  </thead>
  <tbody>
    {{#each meters}}
      <tr>
        <td>{{zoneLabel}}</td>
        <td>{{usageLabel}}</td>
        <td>{{typeLabel}}</td>
        <td class="bool-cell"><span class="{{#if required}}bool-yes{{else}}bool-no{{/if}}">{{#if required}}✓{{else}}✗{{/if}}</span></td>
        <td class="bool-cell"><span class="{{#if present_actual}}bool-yes{{else}}bool-no{{/if}}">{{#if present_actual}}✓{{else}}✗{{/if}}</span></td>
        <td class="bool-cell"><span class="{{#if communicating}}bool-yes{{else}}bool-no{{/if}}">{{#if communicating}}✓{{else}}✗{{/if}}</span></td>
        <td class="bool-cell"><span class="{{#if managed_by_bms}}bool-yes{{else}}bool-no{{/if}}">{{#if managed_by_bms}}✓{{else}}✗{{/if}}</span></td>
        <td class="bool-cell">{{#if out_of_service}}<strong style="color:#b91c1c">HS</strong>{{else}}<span class="bool-na">—</span>{{/if}}</td>
      </tr>
    {{/each}}
  </tbody>
</table>
{{#each meters}}
  {{#if (or notes_html notes photos.length)}}
    <div class="entity-block">
      <h3>{{zoneLabel}} — {{usageLabel}} ({{typeLabel}})</h3>
      {{#if notes_html}}<div class="rich-notes">{{{notes_html}}}</div>
      {{else}}{{#if notes}}<p>{{notes}}</p>{{/if}}{{/if}}
      {{#if photos.length}}
        <div class="photo-grid">
          {{#each photos}}<img src="{{dataUrl}}" alt="" />{{/each}}
        </div>
      {{/if}}
    </div>
  {{/if}}
{{/each}}
{{else}}
<p class="muted">Aucun compteur listé. Saisis les équipements (avec leur énergie) pour générer automatiquement les compteurs requis.</p>
{{/if}}

{{#if isBacs}}
{{!-- ═══════════ Chapitre 5 — Régulation thermique ═══════════ --}}
<h1 class="chapter" data-toc-anchor="thermal">{{{faIcon "fire" "#dc2626" "22"}}} 5. Régulation thermique automatique (R175-6)</h1>

{{#if r175_6_applicable.applies}}
<div class="callout callout-warn">
  <span class="callout-icon">⚠️</span>
  <div class="callout-body"><strong>R175-6 applicable</strong> — {{r175_6_applicable.reason}}.</div>
</div>
{{else}}
<div class="callout callout-reco">
  <span class="callout-icon">✅</span>
  <div class="callout-body"><strong>R175-6 non applicable</strong> — {{r175_6_applicable.reason}}.</div>
</div>
{{/if}}

{{#if thermal.length}}
<table>
  <thead><tr><th>Zone</th><th>Régulation auto</th><th>Type</th><th>Générateur</th><th>Âge</th><th>Exempté bois</th><th>Notes</th></tr></thead>
  <tbody>
    {{#each thermal}}
      <tr>
        <td>{{zone_name}}</td>
        <td class="bool-cell"><span class="{{#if has_automatic_regulation}}bool-yes{{else}}bool-no{{/if}}">{{#if has_automatic_regulation}}✓{{else}}✗{{/if}}</span></td>
        <td>{{regulationLabel}}</td>
        <td>{{generatorLabel}}</td>
        <td>{{#if generator_age_years}}{{generator_age_years}} ans{{/if}}</td>
        <td class="bool-cell">{{#if generator_exempt_wood}}<span class="bool-yes">✓</span> <span class="muted">R175-6 II</span>{{else}}<span class="bool-no">✗</span>{{/if}}</td>
        <td>{{notes}}</td>
      </tr>
    {{/each}}
  </tbody>
</table>
{{else}}
<p class="muted">Régulation thermique non documentée.</p>
{{/if}}
{{/if}}

{{!-- ═══════════ Chapitre 6 — GTB / Supervision ═══════════ --}}
<h1 class="chapter" data-toc-anchor="bms">{{{faIcon "plug" "#7c3aed" "22"}}} {{#if isBacs}}6. Solution GTB / GTC (R175-3, R175-4, R175-5){{else}}5. Solution de supervision en place{{/if}}</h1>
{{#if bms}}
{{#if bms.out_of_service}}
<div class="callout callout-warn">
  <span class="callout-icon">⚠️</span>
  <div class="callout-body"><strong>GTB Hors-Service.</strong> Les exigences R175-3, R175-4 et R175-5 ne sont pas évaluées car la GTB n'est pas opérationnelle au moment de l'audit.</div>
</div>
{{/if}}
<table>
  <tr><th>Solution en place</th><td>{{#if bms.existing_solution}}{{bms.existing_solution}}{{else}}<span class="muted">Non renseigné</span>{{/if}}</td></tr>
  {{#if bms.existing_solution_brand}}<tr><th>Marque / éditeur</th><td>{{bms.existing_solution_brand}}</td></tr>{{/if}}
  {{#if bms.location}}<tr><th>Localisation</th><td>{{bms.location}}</td></tr>{{/if}}
  {{#if bms.model_reference}}<tr><th>Référence modèle</th><td>{{bms.model_reference}}</td></tr>{{/if}}
</table>

<h3>Usages traités par la GTB</h3>
<div class="usage-tags">
  {{#if bms.manages_heating}}<span class="usage-tag">Chauffage</span>{{/if}}
  {{#if bms.manages_cooling}}<span class="usage-tag">Refroidissement</span>{{/if}}
  {{#if bms.manages_ventilation}}<span class="usage-tag">Ventilation</span>{{/if}}
  {{#if bms.manages_dhw}}<span class="usage-tag">ECS</span>{{/if}}
  {{#if bms.manages_lighting}}<span class="usage-tag">Éclairage</span>{{/if}}
  {{#unless bms.manages_heating}}{{#unless bms.manages_cooling}}{{#unless bms.manages_ventilation}}{{#unless bms.manages_dhw}}{{#unless bms.manages_lighting}}<span class="muted">Aucun usage déclaré.</span>{{/unless}}{{/unless}}{{/unless}}{{/unless}}{{/unless}}
</div>

{{#if isBacs}}
<h3>R175-3 — Capacités de supervision</h3>
<div class="kv-list">
  <div class="kv-row">
    <span class="kv-label">P1. Suivi continu, pas horaire, conservation 5 ans</span>
    <span class="kv-value {{#if bms.meets_r175_3_p1}}kv-yes{{else}}kv-no{{/if}}">
      <span class="kv-ico">{{#if bms.meets_r175_3_p1}}✓{{else}}✗{{/if}}</span>{{boolLabel bms.meets_r175_3_p1}}
    </span>
  </div>
  <div class="kv-row">
    <span class="kv-label">P2. Détection des pertes d'efficacité</span>
    <span class="kv-value {{#if bms.meets_r175_3_p2}}kv-yes{{else}}kv-no{{/if}}">
      <span class="kv-ico">{{#if bms.meets_r175_3_p2}}✓{{else}}✗{{/if}}</span>{{boolLabel bms.meets_r175_3_p2}}
    </span>
  </div>
</div>
<div class="callout callout-info">
  <span class="callout-icon">📌</span>
  <div class="callout-body">R175-3 §3 (interopérabilité) et §4 (arrêt manuel + autonome) sont évalués au niveau de chaque équipement (cf chapitre 3).</div>
</div>

<h3>R175-3 dernier alinéa — Mise à disposition des données</h3>
<div class="kv-list">
  <div class="kv-row">
    <span class="kv-label">Procédure de mise à disposition au gestionnaire du bâtiment</span>
    <span class="kv-value {{#if bms.data_provision_to_manager}}kv-yes{{else}}kv-no{{/if}}">
      <span class="kv-ico">{{#if bms.data_provision_to_manager}}✓{{else}}✗{{/if}}</span>{{boolLabel bms.data_provision_to_manager}}
    </span>
  </div>
  <div class="kv-row">
    <span class="kv-label">Procédure de transmission aux exploitants des systèmes techniques</span>
    <span class="kv-value {{#if bms.data_provision_to_operators}}kv-yes{{else}}kv-no{{/if}}">
      <span class="kv-ico">{{#if bms.data_provision_to_operators}}✓{{else}}✗{{/if}}</span>{{boolLabel bms.data_provision_to_operators}}
    </span>
  </div>
</div>
{{#if bms.notes_data_provision}}
<div class="callout callout-info">
  <span class="callout-icon">📌</span>
  <div class="callout-body"><strong>Mécanisme :</strong> {{bms.notes_data_provision}}</div>
</div>
{{/if}}

<h3>R175-4 — Vérifications périodiques</h3>
<div class="kv-list">
  <div class="kv-row">
    <span class="kv-label">Consignes écrites de maintenance présentes</span>
    <span class="kv-value {{#if bms.has_maintenance_procedures}}kv-yes{{else}}kv-no{{/if}}">
      <span class="kv-ico">{{#if bms.has_maintenance_procedures}}✓{{else}}✗{{/if}}</span>{{boolLabel bms.has_maintenance_procedures}}
    </span>
  </div>
</div>

<h3>R175-5 — Formation de l'exploitant</h3>
<div class="kv-list">
  <div class="kv-row">
    <span class="kv-label">Exploitant formé au paramétrage{{#if bms.operator_training_date}} <span class="muted">(formation : {{bms.operator_training_date}})</span>{{/if}}</span>
    <span class="kv-value {{#if bms.operator_trained}}kv-yes{{else}}kv-no{{/if}}">
      <span class="kv-ico">{{#if bms.operator_trained}}✓{{else}}✗{{/if}}</span>{{boolLabel bms.operator_trained}}
    </span>
  </div>
</div>
{{#if buildySolution}}
<div class="callout callout-reco">
  <span class="callout-icon">✅</span>
  <div class="callout-body">
    <strong>Solution Buildy déployée.</strong> L'exigence R175-5 est nativement couverte par le support utilisateur intégré (assistance contextuelle, documentation embarquée, support continu). Cf. Annexe B point 8.
  </div>
</div>
{{/if}}
{{/if}}

{{#if bmsManagedDevices.length}}
<h3>Équipements intégrés à la GTB ({{bmsManagedDevices.length}})</h3>
<div class="compact-list">
  {{#each bmsManagedDevices}}
    <div class="row">
      <strong>{{name}}</strong>
      <span class="meta">{{#if brand}}{{brand}} · {{/if}}zone « {{zone_name}} »</span>
      {{#if power_kw}}<span class="pwr">{{power_kw}} kW</span>{{/if}}
    </div>
  {{/each}}
</div>
{{/if}}

{{#if bmsManagedMeters.length}}
<h3>Compteurs intégrés à la GTB ({{bmsManagedMeters.length}})</h3>
<div class="compact-list">
  {{#each bmsManagedMeters}}
    <div class="row">
      <strong>{{typeLabel}}</strong>
      <span class="meta">{{zoneLabel}} · {{usageLabel}}</span>
    </div>
  {{/each}}
</div>
{{/if}}

{{#if bms.notes_html}}
<div class="entity-block">
  <h3>Notes GTB</h3>
  <div class="rich-notes">{{{bms.notes_html}}}</div>
</div>
{{/if}}
{{#if bms.photos.length}}
<div class="entity-block">
  <h3>Photos GTB</h3>
  <div class="photo-grid">
    {{#each bms.photos}}<img src="{{dataUrl}}" alt="" />{{/each}}
  </div>
</div>
{{/if}}
{{else}}
<p class="muted">Évaluation de la GTB non renseignée.</p>
{{/if}}

{{#if isBacs}}
{{!-- ═══════════ Chapitre 7 — Plan de mise en conformité ═══════════ --}}
<h1 class="chapter" data-toc-anchor="plan">{{{faIcon "list-check" "#f59e0b" "22"}}} 7. Plan de mise en conformité</h1>

{{#if actionItems.blocking.length}}
<h2>Actions bloquantes</h2>
<div class="callout callout-warn">
  <span class="callout-icon">⚠️</span>
  <div class="callout-body">Sans ces actions, le site ne peut pas être considéré comme conforme au décret BACS.</div>
</div>
{{#each actionItems.blocking}}
<div class="action-card">
  <div class="action-card-head">
    <span class="action-num">{{display_number}}</span>
    <span class="sev sev-blocking">Bloquante</span>
    <span class="muted action-card-article">{{r175_article}}</span>
    {{#if zone_name}}<span class="action-card-zone">📍 {{zone_name}}</span>{{/if}}
  </div>
  <div class="action-card-title"><strong>{{title}}</strong></div>
  {{#if description}}<div class="action-card-desc">{{description}}</div>{{/if}}
  {{#if alternative_solutions_html}}
    <div class="alt-solutions">
      <p class="alt-solutions-label">Préconisations Buildy :</p>
      {{{alternative_solutions_html}}}
    </div>
  {{else}}
    <div class="alt-solutions-missing">
      ⚠ <strong>Aucune préconisation renseignée pour cette action.</strong>
    </div>
  {{/if}}
</div>
{{/each}}
{{/if}}

{{#if actionItems.major.length}}
<h2>Actions majeures</h2>
<div class="callout callout-r175">
  <span class="callout-icon">📖</span>
  <div class="callout-body">Impact direct sur les exigences fonctionnelles R175-3.</div>
</div>
{{#each actionItems.major}}
<div class="action-card">
  <div class="action-card-head">
    <span class="action-num">{{display_number}}</span>
    <span class="sev sev-major">Majeure</span>
    <span class="muted action-card-article">{{r175_article}}</span>
    {{#if zone_name}}<span class="action-card-zone">📍 {{zone_name}}</span>{{/if}}
  </div>
  <div class="action-card-title"><strong>{{title}}</strong></div>
  {{#if description}}<div class="action-card-desc">{{description}}</div>{{/if}}
  {{#if alternative_solutions_html}}
    <div class="alt-solutions">
      <p class="alt-solutions-label">Préconisations Buildy :</p>
      {{{alternative_solutions_html}}}
    </div>
  {{else}}
    <div class="alt-solutions-missing">
      ⚠ <strong>Aucune préconisation renseignée pour cette action.</strong>
    </div>
  {{/if}}
</div>
{{/each}}
{{/if}}

{{#if actionItems.minor.length}}
<h2>Optimisations</h2>
<div class="callout callout-info">
  <span class="callout-icon">📌</span>
  <div class="callout-body">Bonnes pratiques, hors strict décret.</div>
</div>
{{#each actionItems.minor}}
<div class="action-card action-card-minor">
  <div class="action-card-head">
    <span class="action-num">{{display_number}}</span>
    <span class="sev sev-minor">Mineure</span>
    <span class="muted action-card-article">{{r175_article}}</span>
    {{#if zone_name}}<span class="action-card-zone">📍 {{zone_name}}</span>{{/if}}
  </div>
  <div class="action-card-title"><strong>{{title}}</strong></div>
  {{#if description}}<div class="action-card-desc">{{description}}</div>{{/if}}
</div>
{{/each}}
{{/if}}

{{#unless actionItems.blocking.length}}
{{#unless actionItems.major.length}}
{{#unless actionItems.minor.length}}
<p>Aucune action corrective à ce stade.</p>
{{/unless}}
{{/unless}}
{{/unless}}

<div class="callout callout-reco" style="margin-top: 8mm;">
  <span class="callout-icon">✅</span>
  <div class="callout-body"><strong>Pour la mise en conformité</strong>, l'équipe commerciale Buildy se tient à votre disposition pour établir un devis chiffré.</div>
</div>
{{/if}}
</div>{{!-- /.sections --}}

{{#if isBacs}}
{{!-- ═══════════ Annexe A — Texte du décret ═══════════ --}}
<section class="annex">
  <h1>Annexe A — Décret BACS (R175-1 à R175-6)</h1>
  {{#each bacsArticles}}
  <h3>{{code}} — {{title}}</h3>
  <div class="muted">{{{html}}}</div>
  {{/each}}
</section>

{{!-- ═══════════ Annexe B — Méthodologie ═══════════ --}}
<section class="annex">
  <h1>Annexe B — Méthodologie et hypothèses retenues par Buildy</h1>
  {{#each methodology}}
  <h3>{{title}}</h3>
  <p>{{body}}</p>
  {{/each}}
</section>

{{!-- ═══════════ Annexe C — Justification des préconisations ═══════════ --}}
<section class="annex">
  <h1>Annexe C — Justification des préconisations</h1>
  <p class="muted">Chaque action corrective listée au chapitre 8 a été générée à partir des données saisies pendant l'audit, en référence à un article précis du décret BACS. Cette annexe trace pour chaque item le raisonnement appliqué.</p>
  {{#each justifications}}
  <h3>{{title}}</h3>
  <p><strong>Article visé :</strong> {{article}}</p>
  <p><strong>Donnée audit :</strong> {{source}}</p>
  <p><strong>Recommandation :</strong> {{description}}</p>
  {{/each}}
  {{#unless justifications.length}}
  <p class="muted">Aucune action corrective générée — pas de justification à reporter.</p>
  {{/unless}}
</section>

{{!-- ═══════════ Annexe D — Disclaimers ═══════════ --}}
<section class="annex">
  <h1>Annexe D — Mentions légales et disclaimers</h1>
  <ol class="disclaimer-list">
    {{#each disclaimers}}
    <li>{{this}}</li>
    {{/each}}
  </ol>
</section>
{{/if}}

</body>
</html>
