<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<title>Audit BACS — {{document.client_name}} — {{document.project_name}}</title>
<style>{{{styles}}}</style>
</head>
<body>

{{!-- ═══════════ Page de garde ═══════════ --}}
<section class="cover">
  <img class="cover-logo" src="{{logoDataUrl}}" alt="Buildy" />
  <p class="cover-doc-type">Audit BACS — Décret R175</p>
  <h1 class="cover-title">{{document.project_name}}</h1>
  <p class="cover-client">{{document.client_name}}</p>
  {{#if site.name}}<p class="cover-project">Site : {{site.name}}</p>{{/if}}
  {{#if site.address}}<p class="cover-address">{{site.address}}</p>{{/if}}

  {{#if applicabilityLabel}}
  <div class="cover-deadline-block">
    <p class="cover-deadline-label">Applicabilité R175-2</p>
    <p class="cover-deadline-value">{{applicabilityLabel}}</p>
    {{#if document.bacs_total_power_kw}}
    <p class="cover-deadline-detail">
      Puissance nominale utile cumulée chauffage + climatisation : <strong>{{document.bacs_total_power_kw}} kW</strong>
    </p>
    {{/if}}
  </div>
  {{/if}}

  <div class="cover-meta">
    <div class="cover-meta-row">
      <span class="cover-meta-label">Date d'audit</span>
      <span class="cover-meta-value">{{exportDate}}</span>
    </div>
    <div class="cover-meta-row">
      <span class="cover-meta-label">Auteur</span>
      <span class="cover-meta-value">{{authorName}}</span>
    </div>
    <div class="cover-meta-row">
      <span class="cover-meta-label">Version</span>
      <span class="cover-meta-value"><span class="cover-version-tag">{{version}}</span></span>
    </div>
    <div class="cover-meta-row">
      <span class="cover-meta-label">Type de document</span>
      <span class="cover-meta-value">Audit de conformité BACS</span>
    </div>
  </div>
</section>

{{#if synthesisHtml}}
{{!-- ═══════════ Synthèse executive ═══════════ --}}
<h1 class="chapter">Note de synthèse</h1>
<div class="synthesis-block">{{{synthesisHtml}}}</div>
{{/if}}

{{!-- ═══════════ Chapitre 1 — Identification site ═══════════ --}}
<h1 class="chapter">1. Identification du site</h1>
<table>
  <tr><th>Site</th><td>{{site.name}}</td></tr>
  <tr><th>Client</th><td>{{document.client_name}}</td></tr>
  <tr><th>Adresse</th><td>{{site.address}}</td></tr>
  {{#if document.bacs_total_power_kw}}
  <tr><th>Puissance cumulée chauffage + climatisation</th><td>{{document.bacs_total_power_kw}} kW</td></tr>
  {{/if}}
  {{#if document.bacs_building_permit_date}}
  <tr><th>Date de permis de construire</th><td>{{document.bacs_building_permit_date}}</td></tr>
  {{/if}}
  {{#if applicabilityLabel}}
  <tr><th>Applicabilité BACS (R175-2)</th><td>{{applicabilityLabel}}</td></tr>
  {{/if}}
</table>

{{#if heatingCoolingBreakdown.length}}
<h3>Détail du calcul automatique de la puissance</h3>
<p class="muted" style="margin-bottom:2mm">
  La puissance cumulée chauffage + climatisation est obtenue en additionnant
  les puissances nominales utiles des équipements saisis dans les catégories
  <strong>chauffage</strong> et <strong>climatisation</strong> (chapitre 3).
</p>
<table>
  <thead>
    <tr><th>Équipement</th><th>Marque / référence</th><th>Catégorie</th><th>Zone</th><th>Puissance</th></tr>
  </thead>
  <tbody>
    {{#each heatingCoolingBreakdown}}
      <tr>
        <td>{{name}}</td>
        <td>{{brand}}{{#if model_reference}} / {{model_reference}}{{/if}}</td>
        <td>{{categoryLabel}}</td>
        <td>{{zone_name}}</td>
        <td><strong>{{power_kw}} kW</strong></td>
      </tr>
    {{/each}}
    <tr style="background:#eef2ff">
      <td colspan="4" style="text-align:right"><strong>Total chauffage + climatisation</strong></td>
      <td><strong>{{heatingCoolingTotal}} kW</strong></td>
    </tr>
  </tbody>
</table>
{{/if}}

<p class="muted">
  À titre informatif : l'article R175-2 prévoit une clause de dispense applicable
  lorsque le temps de retour sur investissement de la mise en conformité dépasse
  10 ans. Ce calcul ne relève pas du périmètre du présent audit (cf. Annexe D,
  point 4).
</p>

{{!-- ═══════════ Chapitre 2 — Zones fonctionnelles ═══════════ --}}
<h1 class="chapter">2. Zones fonctionnelles (R175-1 §6)</h1>
{{#if zones.length}}
<table>
  <thead><tr><th>Zone</th><th>Nature</th><th>Surface (m²)</th></tr></thead>
  <tbody>
    {{#each zones}}
      <tr><td>{{name}}</td><td>{{nature}}</td><td>{{surface_m2}}</td></tr>
    {{/each}}
  </tbody>
</table>
{{#each zones}}
  {{#if (or notes_html notes photos.length)}}
    <div class="entity-block">
      <h3>{{name}}</h3>
      {{#if notes_html}}<div class="rich-notes">{{{notes_html}}}</div>
      {{else}}{{#if notes}}<p>{{notes}}</p>{{/if}}{{/if}}
      {{#if photos.length}}
        <div class="photo-grid">
          {{#each photos}}<img src="{{dataUrl}}" alt="" />{{/each}}
        </div>
      {{/if}}
    </div>
  {{/if}}
{{/each}}
{{else}}
<p class="muted">Aucune zone définie.</p>
{{/if}}

{{!-- ═══════════ Chapitre 3 — Systèmes techniques ═══════════ --}}
<h1 class="chapter">3. Systèmes techniques par zone (R175-1 §4)</h1>
{{#each systemsByZone}}
<h2>{{zone_name}} <span class="muted">({{zone_nature}})</span></h2>
{{#each items}}
  {{#if present}}
    <h3>{{categoryLabel}}{{#if total_power_kw}} <span class="muted">— {{total_power_kw}} kW total ({{device_count}} équipement{{#if device_count}}{{#unless (eq device_count 1)}}s{{/unless}}{{/if}})</span>{{/if}}</h3>
    {{#if devices.length}}
      <table>
        <thead>
          <tr>
            <th>Nom</th><th>Marque</th><th>Modèle</th><th>Énergie</th>
            <th>Puiss. (kW)</th><th>Nature</th><th>Communication</th>
            <th>Localisation</th><th>Comm. R175-3 §3</th><th>Arrêt manuel</th>
            <th>Autonome</th><th>HS</th>
          </tr>
        </thead>
        <tbody>
          {{#each devices}}
            <tr>
              <td>{{name}}</td>
              <td>{{brand}}</td>
              <td>{{model_reference}}</td>
              <td>{{energyLabel}}</td>
              <td>{{power_kw}}</td>
              <td>{{roleLabel}}</td>
              <td>{{commLabel}}</td>
              <td>{{location}}</td>
              <td>{{#if communication_protocol}}{{#unless (eq communication_protocol "non_communicant")}}{{#unless (eq communication_protocol "absent")}}Oui{{else}}Non{{/unless}}{{else}}Non{{/unless}}{{else}}Non{{/if}}</td>
              <td>{{boolLabel meets_r175_3_p4}}</td>
              <td>{{boolLabel meets_r175_3_p4_autonomous}}</td>
              <td>{{#if out_of_service}}<strong style="color:#b91c1c">HS</strong>{{else}}—{{/if}}</td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p class="muted">Système marqué présent mais aucun équipement détaillé n'a été saisi.</p>
    {{/if}}
    {{#if notes_html}}
      <div class="rich-notes">{{{notes_html}}}</div>
    {{else}}{{#if notes}}<p class="muted"><em>Notes :</em> {{notes}}</p>{{/if}}{{/if}}
    {{#if photos.length}}
      <div class="photo-grid">
        {{#each photos}}<img src="{{dataUrl}}" alt="" />{{/each}}
      </div>
    {{/if}}
    {{#each devices}}
      {{#if (or notes_html photos.length)}}
        <div class="device-notes">
          <strong class="muted">{{name}}{{#if brand}} — {{brand}}{{/if}}{{#if model_reference}} {{model_reference}}{{/if}}</strong>
          {{#if notes_html}}<div class="rich-notes">{{{notes_html}}}</div>{{/if}}
          {{#if photos.length}}
            <div class="photo-grid">
              {{#each photos}}<img src="{{dataUrl}}" alt="" />{{/each}}
            </div>
          {{/if}}
        </div>
      {{/if}}
    {{/each}}
  {{else}}
    <h3 class="muted">{{categoryLabel}} — non présent</h3>
  {{/if}}
{{/each}}
{{/each}}

{{!-- ═══════════ Chapitre 4 — Compteurs ═══════════ --}}
<h1 class="chapter">4. Compteurs et mesurage (R175-3 §1)</h1>
{{#if meters.length}}
<table>
  <thead>
    <tr>
      <th>Zone</th><th>Usage</th><th>Type</th>
      <th>Requis</th><th>Présent</th><th>Communicant</th><th>Intégré GTB</th><th>HS</th>
    </tr>
  </thead>
  <tbody>
    {{#each meters}}
      <tr>
        <td>{{zoneLabel}}</td>
        <td>{{usageLabel}}</td>
        <td>{{typeLabel}}</td>
        <td>{{#if required}}Oui{{else}}Non{{/if}}</td>
        <td>{{#if present_actual}}Oui{{else}}Non{{/if}}</td>
        <td>{{#if communicating}}Oui{{else}}Non{{/if}}</td>
        <td>{{#if managed_by_bms}}Oui{{else}}Non{{/if}}</td>
        <td>{{#if out_of_service}}<strong style="color:#b91c1c">HS</strong>{{else}}—{{/if}}</td>
      </tr>
    {{/each}}
  </tbody>
</table>
{{#each meters}}
  {{#if (or notes_html notes photos.length)}}
    <div class="entity-block">
      <h3>{{zoneLabel}} — {{usageLabel}} ({{typeLabel}})</h3>
      {{#if notes_html}}<div class="rich-notes">{{{notes_html}}}</div>
      {{else}}{{#if notes}}<p>{{notes}}</p>{{/if}}{{/if}}
      {{#if photos.length}}
        <div class="photo-grid">
          {{#each photos}}<img src="{{dataUrl}}" alt="" />{{/each}}
        </div>
      {{/if}}
    </div>
  {{/if}}
{{/each}}
{{else}}
<p class="muted">Aucun compteur listé. Saisis les équipements (avec leur énergie) pour générer automatiquement les compteurs requis.</p>
{{/if}}

{{!-- ═══════════ Chapitre 5 — Régulation thermique ═══════════ --}}
<h1 class="chapter">5. Régulation thermique automatique (R175-6)</h1>
{{#if thermal.length}}
<table>
  <thead><tr><th>Zone</th><th>Régulation auto</th><th>Type</th><th>Générateur</th><th>Âge</th><th>Notes</th></tr></thead>
  <tbody>
    {{#each thermal}}
      <tr>
        <td>{{zone_name}}</td>
        <td>{{#if has_automatic_regulation}}Oui{{else}}Non{{/if}}</td>
        <td>{{regulationLabel}}</td>
        <td>{{generatorLabel}}</td>
        <td>{{#if generator_age_years}}{{generator_age_years}} ans{{/if}}</td>
        <td>{{notes}}</td>
      </tr>
    {{/each}}
  </tbody>
</table>
{{else}}
<p class="muted">Régulation thermique non documentée.</p>
{{/if}}

{{!-- ═══════════ Chapitre 6 — GTB ═══════════ --}}
<h1 class="chapter">6. Solution GTB / GTC (R175-3, R175-4, R175-5)</h1>
{{#if bms}}
{{#if bms.out_of_service}}
<p style="background:#fee2e2;border:1px solid #fca5a5;padding:3mm;border-radius:1mm;color:#991b1b;">
  <strong>GTB Hors-Service.</strong> Les exigences R175-3, R175-4 et R175-5 ne sont pas évaluées car la GTB n'est pas opérationnelle au moment de l'audit.
</p>
{{/if}}
<table>
  <tr><th>Solution en place</th><td>{{#if bms.existing_solution}}{{bms.existing_solution}}{{else}}<span class="muted">Non renseigné</span>{{/if}}</td></tr>
  {{#if bms.existing_solution_brand}}<tr><th>Marque / éditeur</th><td>{{bms.existing_solution_brand}}</td></tr>{{/if}}
  {{#if bms.location}}<tr><th>Localisation</th><td>{{bms.location}}</td></tr>{{/if}}
  {{#if bms.model_reference}}<tr><th>Référence modèle</th><td>{{bms.model_reference}}</td></tr>{{/if}}
</table>

<h3>Usages traités par la GTB</h3>
<p>
  {{#if bms.manages_heating}}<span style="display:inline-block;padding:1mm 2mm;background:#eef2ff;color:#4338ca;border-radius:1mm;margin:0.5mm">Chauffage</span>{{/if}}
  {{#if bms.manages_cooling}}<span style="display:inline-block;padding:1mm 2mm;background:#eef2ff;color:#4338ca;border-radius:1mm;margin:0.5mm">Refroidissement</span>{{/if}}
  {{#if bms.manages_ventilation}}<span style="display:inline-block;padding:1mm 2mm;background:#eef2ff;color:#4338ca;border-radius:1mm;margin:0.5mm">Ventilation</span>{{/if}}
  {{#if bms.manages_dhw}}<span style="display:inline-block;padding:1mm 2mm;background:#eef2ff;color:#4338ca;border-radius:1mm;margin:0.5mm">ECS</span>{{/if}}
  {{#if bms.manages_lighting}}<span style="display:inline-block;padding:1mm 2mm;background:#eef2ff;color:#4338ca;border-radius:1mm;margin:0.5mm">Éclairage</span>{{/if}}
  {{#unless bms.manages_heating}}{{#unless bms.manages_cooling}}{{#unless bms.manages_ventilation}}{{#unless bms.manages_dhw}}{{#unless bms.manages_lighting}}<span class="muted">Aucun usage déclaré.</span>{{/unless}}{{/unless}}{{/unless}}{{/unless}}{{/unless}}
</p>

<h3>R175-3 — Capacités de supervision</h3>
<table>
  <tr><td>P1. Suivi continu, pas horaire, conservation 5 ans</td><td>{{boolLabel bms.meets_r175_3_p1}}</td></tr>
  <tr><td>P2. Détection des pertes d'efficacité</td><td>{{boolLabel bms.meets_r175_3_p2}}</td></tr>
</table>
<p class="muted"><em>Note : R175-3 §3 (interopérabilité) et §4 (arrêt manuel + autonome) sont évalués au niveau de chaque équipement (cf chapitre 3).</em></p>

<h3>R175-4 — Vérifications périodiques</h3>
<p>Consignes écrites de maintenance présentes : <strong>{{boolLabel bms.has_maintenance_procedures}}</strong></p>
<h3>R175-5 — Formation de l'exploitant</h3>
<p>Exploitant formé au paramétrage : <strong>{{boolLabel bms.operator_trained}}</strong>{{#if bms.operator_training_date}} (formation : {{bms.operator_training_date}}){{/if}}</p>
{{#if buildySolution}}
<p class="muted">
  La solution déployée est Buildy : l'exigence R175-5 est nativement couverte
  par le support utilisateur intégré (assistance contextuelle, documentation
  embarquée, support continu). Cf. Annexe B point 8.
</p>
{{/if}}

{{#if bmsManagedDevices.length}}
<h3>Équipements intégrés à la GTB ({{bmsManagedDevices.length}})</h3>
<ul>
  {{#each bmsManagedDevices}}
    <li>
      <strong>{{name}}</strong>{{#if brand}} — {{brand}}{{/if}}
      <span class="muted">— zone « {{zone_name}} »{{#if power_kw}}, {{power_kw}} kW{{/if}}</span>
    </li>
  {{/each}}
</ul>
{{/if}}

{{#if bmsManagedMeters.length}}
<h3>Compteurs intégrés à la GTB ({{bmsManagedMeters.length}})</h3>
<ul>
  {{#each bmsManagedMeters}}
    <li><strong>{{typeLabel}}</strong> — {{zoneLabel}} ({{usageLabel}})</li>
  {{/each}}
</ul>
{{/if}}

{{#if bms.notes_html}}
<div class="entity-block">
  <h3>Notes GTB</h3>
  <div class="rich-notes">{{{bms.notes_html}}}</div>
</div>
{{/if}}
{{#if bms.photos.length}}
<div class="entity-block">
  <h3>Photos GTB</h3>
  <div class="photo-grid">
    {{#each bms.photos}}<img src="{{dataUrl}}" alt="" />{{/each}}
  </div>
</div>
{{/if}}
{{else}}
<p class="muted">Évaluation de la GTB non renseignée.</p>
{{/if}}

{{!-- ═══════════ Chapitre 7 — Synthèse ═══════════ --}}
<h1 class="chapter">7. Synthèse de conformité</h1>
{{#if bms.overall_compliance}}
<p>État global : <span class="status status-{{bms.overall_compliance}}">{{complianceLabel}}</span></p>
{{/if}}
<table>
  <thead><tr><th>Sévérité</th><th>Nombre</th></tr></thead>
  <tbody>
    <tr><td><span class="sev sev-blocking">Bloquantes</span></td><td>{{actionStats.blocking}}</td></tr>
    <tr><td><span class="sev sev-major">Majeures</span></td><td>{{actionStats.major}}</td></tr>
    <tr><td><span class="sev sev-minor">Mineures</span></td><td>{{actionStats.minor}}</td></tr>
  </tbody>
</table>

{{!-- ═══════════ Chapitre 8 — Plan de mise en conformité ═══════════ --}}
<h1 class="chapter">8. Plan de mise en conformité</h1>

{{#if actionItems.blocking.length}}
<h2>Actions bloquantes</h2>
<p class="muted">Sans ces actions, le site ne peut pas être considéré comme conforme au décret BACS.</p>
<table>
  <thead><tr><th>Article</th><th>Action</th><th>Zone</th><th>Description</th></tr></thead>
  <tbody>
    {{#each actionItems.blocking}}
      <tr>
        <td><span class="muted">{{r175_article}}</span></td>
        <td>{{title}}</td>
        <td>{{zone_name}}</td>
        <td>{{description}}</td>
      </tr>
    {{/each}}
  </tbody>
</table>
{{/if}}

{{#if actionItems.major.length}}
<h2>Actions majeures</h2>
<p class="muted">Impact direct sur les exigences fonctionnelles R175-3.</p>
<table>
  <thead><tr><th>Article</th><th>Action</th><th>Zone</th><th>Description</th></tr></thead>
  <tbody>
    {{#each actionItems.major}}
      <tr>
        <td><span class="muted">{{r175_article}}</span></td>
        <td>{{title}}</td>
        <td>{{zone_name}}</td>
        <td>{{description}}</td>
      </tr>
    {{/each}}
  </tbody>
</table>
{{/if}}

{{#if actionItems.minor.length}}
<h2>Optimisations</h2>
<p class="muted">Bonnes pratiques, hors strict décret.</p>
<table>
  <thead><tr><th>Article</th><th>Action</th><th>Zone</th></tr></thead>
  <tbody>
    {{#each actionItems.minor}}
      <tr>
        <td><span class="muted">{{r175_article}}</span></td>
        <td>{{title}}</td>
        <td>{{zone_name}}</td>
      </tr>
    {{/each}}
  </tbody>
</table>
{{/if}}

{{#unless actionItems.blocking.length}}
{{#unless actionItems.major.length}}
{{#unless actionItems.minor.length}}
<p>Aucune action corrective à ce stade.</p>
{{/unless}}
{{/unless}}
{{/unless}}

<p style="margin-top: 8mm; padding: 4mm; background: #eef2ff; border-left: 3px solid #4f46e5; border-radius: 1mm; font-size: 10pt;">
  Pour la mise en conformité, l'équipe commerciale Buildy se tient à votre
  disposition pour établir un devis chiffré.
</p>

{{!-- ═══════════ Annexe A — Texte du décret ═══════════ --}}
<section class="annex">
  <h1>Annexe A — Décret BACS (R175-1 à R175-6)</h1>
  {{#each bacsArticles}}
  <h3>{{code}} — {{title}}</h3>
  <div class="muted">{{{html}}}</div>
  {{/each}}
</section>

{{!-- ═══════════ Annexe B — Méthodologie ═══════════ --}}
<section class="annex">
  <h1>Annexe B — Méthodologie et hypothèses retenues par Buildy</h1>
  {{#each methodology}}
  <h3>{{title}}</h3>
  <p>{{body}}</p>
  {{/each}}
</section>

{{!-- ═══════════ Annexe C — Justification des préconisations ═══════════ --}}
<section class="annex">
  <h1>Annexe C — Justification des préconisations</h1>
  <p class="muted">Chaque action corrective listée au chapitre 8 a été générée à partir des données saisies pendant l'audit, en référence à un article précis du décret BACS. Cette annexe trace pour chaque item le raisonnement appliqué.</p>
  {{#each justifications}}
  <h3>{{title}}</h3>
  <p><strong>Article visé :</strong> {{article}}</p>
  <p><strong>Donnée audit :</strong> {{source}}</p>
  <p><strong>Recommandation :</strong> {{description}}</p>
  {{/each}}
  {{#unless justifications.length}}
  <p class="muted">Aucune action corrective générée — pas de justification à reporter.</p>
  {{/unless}}
</section>

{{!-- ═══════════ Annexe D — Disclaimers ═══════════ --}}
<section class="annex">
  <h1>Annexe D — Mentions légales et disclaimers</h1>
  <ol class="disclaimer-list">
    {{#each disclaimers}}
    <li>{{this}}</li>
    {{/each}}
  </ol>
</section>

</body>
</html>
