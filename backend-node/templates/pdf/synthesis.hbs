<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<title>Synthèse — {{af.client_name}} — {{af.project_name}}</title>
<style>{{{styles}}}</style>
</head>
<body>

{{!-- ═══════════════════ PAGE 1 — Bilan projet (tableau compact) ═══════════════════ --}}
<section class="page">
  <header class="page-header">
    <div class="page-header-left">
      <img class="page-logo" src="{{logoDataUrl}}" alt="Buildy" />
      <div>
        <p class="page-doctype">Synthèse de l'analyse fonctionnelle</p>
        <h1 class="page-title">{{af.client_name}} — {{af.project_name}}</h1>
        {{#if af.site_address}}<p class="page-subtitle">{{af.site_address}}</p>{{/if}}
      </div>
    </div>
    <div class="page-header-right">
      <p class="page-meta"><span class="meta-label">Version</span> <span class="version-tag">{{version}}</span></p>
      <p class="page-meta"><span class="meta-label">Date</span> {{exportDate}}</p>
      <p class="page-meta"><span class="meta-label">Auteur</span> {{authorName}}</p>
    </div>
  </header>

  <h2 class="section-h">1. Bilan du projet</h2>

  <table class="summary-2col">
    <tbody>
      <tr><th>Niveau de contrat Buildy requis</th><td><span class="lvl-pill lvl-{{kpis.requiredLevel}}">{{#if kpis.requiredLevelLabel}}{{kpis.requiredLevelLabel}}{{else}}—{{/if}}</span></td></tr>
      <tr><th>Niveau de contrat actuel</th><td>{{#if kpis.contractLevelLabel}}<span class="lvl-pill lvl-{{kpis.contractLevel}}">{{kpis.contractLevelLabel}}</span>{{else}}<em class="muted">à définir au bon de commande</em>{{/if}}</td></tr>
      <tr><th>Verdict</th><td><span class="verdict-inline verdict-{{kpis.verdict.kind}}">{{kpis.verdict.text}}</span></td></tr>
      <tr><th>Catégories de systèmes supervisées</th><td><strong>{{kpis.systemsCovered}}</strong> sur {{kpis.systemsCatalog}} disponibles au catalogue</td></tr>
      <tr><th>Instances d'équipement déclarées</th><td><strong>{{kpis.instancesTotal}}</strong></td></tr>
      <tr><th>Points contractuels (lecture + écriture)</th><td><strong>{{kpis.pointsTotal}}</strong></td></tr>
      <tr><th>Fonctionnalités Buildy intégrées au projet</th><td><strong>{{functionalitiesIncluded}}</strong> sur {{functionalities.length}} décrites dans l'AF</td></tr>
    </tbody>
  </table>

  {{#if optedOutList.length}}
  <h2 class="section-h" style="margin-top: 8mm;">Fonctionnalités écartées par la maîtrise d'ouvrage</h2>
  <table class="opted-table">
    <thead><tr><th>Numéro</th><th>Titre</th><th>Contrat requis pour activer</th></tr></thead>
    <tbody>
      {{#each optedOutList}}
      <tr><td><code>§{{number}}</code></td><td>{{title}}</td><td><span class="lvl-pill lvl-warn">{{requiredContract}}</span></td></tr>
      {{/each}}
    </tbody>
  </table>
  {{/if}}
</section>

{{!-- ═══════════════════ PAGE 2 — Zones fonctionnelles × catégories ═══════════════════ --}}
<section class="page">
  <header class="page-header">
    <div class="page-header-left">
      <img class="page-logo" src="{{logoDataUrl}}" alt="Buildy" />
      <div>
        <p class="page-doctype">Synthèse — {{af.client_name}} {{af.project_name}}</p>
        <h1 class="page-title">2. Zones fonctionnelles du bâtiment</h1>
      </div>
    </div>
    <div class="page-header-right">
      <p class="page-meta"><span class="meta-label">Version</span> <span class="version-tag">{{version}}</span></p>
    </div>
  </header>

  {{#if hasZones}}
  <p class="section-intro">Nombre d'instances d'équipements prévues par zone et par catégorie. Les colonnes marquées <span class="bacs-col-marker">⚖️</span> correspondent à des systèmes <strong>visés par le décret BACS</strong> (R175-1 §1 chauffage, §2 climatisation, §3 ventilation, §4 systèmes techniques de bâtiment).</p>

  <table class="zones-matrix">
    <thead>
      <tr class="zones-cat-row">
        <th class="zones-name" rowspan="2">Zone</th>
        {{#each systemCategories}}<th class="zones-cat">{{label}}</th>{{/each}}
        <th class="zones-total" rowspan="2">Total</th>
      </tr>
      <tr class="zones-bacs-row">
        {{#each systemCategories}}
          {{#if bacs}}<th class="zones-bacs"><span class="bacs-col-marker" title="{{bacs}}">⚖️ {{bacs}}</span></th>{{else}}<th class="zones-bacs muted">—</th>{{/if}}
        {{/each}}
      </tr>
    </thead>
    <tbody>
      {{#each zonesMatrix}}
      <tr>
        <td class="zones-name"><strong>{{name}}</strong>{{#if surface_m2}} <span class="muted">({{surface_m2}} m²)</span>{{/if}}</td>
        {{#each cells}}<td class="zones-cell">{{#if this}}<strong>{{this}}</strong>{{else}}<span class="muted">—</span>{{/if}}</td>{{/each}}
        <td class="zones-total"><strong>{{total}}</strong></td>
      </tr>
      {{/each}}
    </tbody>
    <tfoot>
      <tr>
        <td class="zones-name">Total par catégorie</td>
        {{#each zonesColTotals}}<td class="zones-cell"><strong>{{this}}</strong></td>{{/each}}
        <td class="zones-total"><strong>{{zonesGrandTotal}}</strong></td>
      </tr>
    </tfoot>
  </table>

  {{#if unzonedInstances}}
  <p class="legal-note"><strong>{{unzonedInstances}} instance{{#if (gt unzonedInstances 1)}}s{{/if}}</strong> d'équipement {{#if (gt unzonedInstances 1)}}n'ont{{else}}n'a{{/if}} pas pu être rattachée{{#if (gt unzonedInstances 1)}}s{{/if}} à une zone fonctionnelle (champ « Localisation » de l'instance vide ou ne contenant pas le nom d'une zone définie).</p>
  {{/if}}
  {{else}}
  <p class="empty-state">Aucune zone fonctionnelle déclarée dans cette AF. Pour activer cette synthèse, ajoutez des zones depuis la section « Zones fonctionnelles du bâtiment » de l'AF.</p>
  {{/if}}
</section>

{{!-- ═══════════════════ PAGE 3 — Synthèse des fonctionnalités ═══════════════════ --}}
<section class="page">
  <header class="page-header">
    <div class="page-header-left">
      <img class="page-logo" src="{{logoDataUrl}}" alt="Buildy" />
      <div>
        <p class="page-doctype">Synthèse — {{af.client_name}} {{af.project_name}}</p>
        <h1 class="page-title">3. Fonctionnalités Buildy</h1>
      </div>
    </div>
    <div class="page-header-right">
      <p class="page-meta"><span class="meta-label">Version</span> <span class="version-tag">{{version}}</span></p>
    </div>
  </header>

  <p class="section-intro">Liste exhaustive des fonctionnalités décrites dans l'AF. La colonne <strong>Intégrée au projet</strong> indique si chaque fonctionnalité sera disponible à la livraison, en tenant compte du niveau de contrat actuel, des écartements MOA et des sections exclues de l'export.</p>

  <table class="features-table">
    <thead>
      <tr>
        <th class="ft-num">Numéro</th>
        <th class="ft-title">Fonctionnalité</th>
        <th class="ft-level">Niveau d'offre requis</th>
        <th class="ft-include">Intégrée au projet</th>
        <th class="ft-reason">Motif si non intégrée</th>
      </tr>
    </thead>
    <tbody>
      {{#each functionalities}}
      <tr class="ft-row {{#unless included}}ft-row-out{{/unless}}">
        <td class="ft-num"><code>§{{number}}</code></td>
        <td class="ft-title">{{title}}</td>
        <td class="ft-level"><span class="lvl-pill lvl-{{levelClass}}">{{serviceLevelLabel}}</span></td>
        <td class="ft-include">
          {{#if included}}<span class="check-yes">✓</span>{{else}}<span class="check-no">✗</span>{{/if}}
        </td>
        <td class="ft-reason">{{#if reason}}<em>{{reason}}</em>{{else}}<span class="muted">—</span>{{/if}}</td>
      </tr>
      {{/each}}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="3">Total</td>
        <td class="ft-include"><strong>{{functionalitiesIncluded}}/{{functionalities.length}}</strong></td>
        <td></td>
      </tr>
    </tfoot>
  </table>
</section>

{{!-- ═══════════════════ PAGE 4 — Synthèse des systèmes ═══════════════════ --}}
<section class="page">
  <header class="page-header">
    <div class="page-header-left">
      <img class="page-logo" src="{{logoDataUrl}}" alt="Buildy" />
      <div>
        <p class="page-doctype">Synthèse — {{af.client_name}} {{af.project_name}}</p>
        <h1 class="page-title">4. Systèmes techniques supervisés</h1>
      </div>
    </div>
    <div class="page-header-right">
      <p class="page-meta"><span class="meta-label">Version</span> <span class="version-tag">{{version}}</span></p>
    </div>
  </header>

  <p class="section-intro">Liste de toutes les catégories de systèmes décrites dans l'AF, avec leur statut au regard du décret BACS, le nombre d'instances déclarées sur le site et le total de points en lecture / écriture.</p>

  <table class="systems-table">
    <thead>
      <tr>
        <th class="sys-num">Numéro</th>
        <th class="sys-title">Système</th>
        <th class="sys-bacs">Exigé par BACS</th>
        <th class="sys-status">Statut</th>
        <th class="sys-num-cell">Instances</th>
        <th class="sys-num-cell">Points lecture</th>
        <th class="sys-num-cell">Points écriture</th>
      </tr>
    </thead>
    <tbody>
      {{#each systemsSummary}}
      <tr class="sys-row sys-row-{{statusClass}}">
        <td class="sys-num"><code>§{{number}}</code></td>
        <td class="sys-title">{{title}}</td>
        <td class="sys-bacs">
          {{#if bacs}}<span class="check-yes">✓</span> <span class="m-bacs-tag">{{bacs}}</span>
          {{else if isMetering}}<span class="muted-italic">contribue R175-3 §1</span>
          {{else}}<span class="check-no">✗</span>
          {{/if}}
        </td>
        <td class="sys-status"><span class="status-pill status-{{statusClass}}">{{status}}</span></td>
        <td class="sys-num-cell">{{#if instances}}<strong>{{instances}}</strong>{{else}}<span class="muted">0</span>{{/if}}</td>
        <td class="sys-num-cell">{{#if totalReads}}<strong>{{totalReads}}</strong>{{else}}<span class="muted">—</span>{{/if}}</td>
        <td class="sys-num-cell">{{#if totalWrites}}<strong>{{totalWrites}}</strong>{{else}}<span class="muted">—</span>{{/if}}</td>
      </tr>
      {{/each}}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="4">Total projet</td>
        <td class="sys-num-cell"><strong>{{systemsTotals.instances}}</strong></td>
        <td class="sys-num-cell"><strong>{{systemsTotals.totalReads}}</strong></td>
        <td class="sys-num-cell"><strong>{{systemsTotals.totalWrites}}</strong></td>
      </tr>
    </tfoot>
  </table>
</section>

</body>
</html>
