<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <title>Offres Buildy {{year}}</title>
  <style>{{{styles}}}</style>
</head>
<body>

{{!-- ═══════════ Page de garde ═══════════ --}}
<section class="cover">
  <img class="cover-logo" src="{{logoDataUrl}}" alt="Buildy" />
  <p class="cover-doc-type">Catalogue commercial</p>
  <h1 class="cover-title">Offres Buildy<br/>{{year}}</h1>
  <div class="cover-promise">{{{coverPromise}}}</div>
  <p class="cover-subtitle">{{{coverSubtitle}}}</p>
  <p class="cover-meta">Édition du {{exportDate}}</p>
</section>

{{!-- ═══════════ Tableau comparatif ═══════════ --}}
<section class="comparison">
  <header class="comparison-head">
    <h1 class="page-title">Tableau des offres Buildy</h1>
    <div class="comparison-legend">
      <span class="legend-item"><span class="avail avail-included">✓</span> Inclus</span>
      <span class="legend-item"><span class="avail avail-option">⓪</span> Option</span>
      <span class="legend-item"><span class="avail avail-unavailable">—</span> Non dispo</span>
    </div>
  </header>

  <table class="comparison-table">
    <colgroup>
      <col class="col-feature" />
      {{#each levels}}<col class="col-level" />{{/each}}
    </colgroup>
    <thead>
      <tr>
        <th class="th-feature">Fonctionnalité</th>
        {{#each levels}}
        <th class="th-level th-{{slug}} {{#if is_highlighted}}th-highlighted{{/if}}"
            {{#if color_hex}}style="background:{{color_hex}};"{{/if}}>
          {{#if is_highlighted}}{{#if highlight_label}}
          <div class="th-level-badge">{{highlight_label}}</div>
          {{/if}}{{/if}}
          <div class="th-level-name">{{name}}</div>
          {{#if tagline}}<div class="th-level-tagline">{{tagline}}</div>{{/if}}
        </th>
        {{/each}}
      </tr>
    </thead>
    <tbody>
      {{#each rows}}
      {{#if (eq kind "category")}}
      <tr class="category-row category-row-d{{depth}}">
        <td colspan="{{../colspan}}">
          <span class="cat-marker cat-marker-d{{depth}}">{{#if (eq depth 0)}}▸{{else}}·{{/if}}</span>
          {{title}}
        </td>
      </tr>
      {{else}}
      <tr>
        <td class="td-feature td-feature-d{{depth}}">{{title}}</td>
        {{#each ../levels}}
        {{#if (eq slug "E")}}
          <td class="td-level td-level-{{slug}} {{#if is_highlighted}}td-level-highlighted{{/if}}"><span class="avail avail-{{../avail_e}}">{{#if (eq ../avail_e "included")}}✓{{else}}{{#if (eq ../avail_e "option")}}⓪{{else}}—{{/if}}{{/if}}</span></td>
        {{/if}}
        {{#if (eq slug "S")}}
          <td class="td-level td-level-{{slug}} {{#if is_highlighted}}td-level-highlighted{{/if}}"><span class="avail avail-{{../avail_s}}">{{#if (eq ../avail_s "included")}}✓{{else}}{{#if (eq ../avail_s "option")}}⓪{{else}}—{{/if}}{{/if}}</span></td>
        {{/if}}
        {{#if (eq slug "P")}}
          <td class="td-level td-level-{{slug}} {{#if is_highlighted}}td-level-highlighted{{/if}}"><span class="avail avail-{{../avail_p}}">{{#if (eq ../avail_p "included")}}✓{{else}}{{#if (eq ../avail_p "option")}}⓪{{else}}—{{/if}}{{/if}}</span></td>
        {{/if}}
        {{/each}}
      </tr>
      {{/if}}
      {{/each}}
    </tbody>
  </table>

  <div class="cta-block">
    <p class="cta-line">{{{ctaTitle}}}</p>
    <p class="cta-sub">{{{ctaSub}}}</p>
    <p class="cta-contact">{{{ctaContact}}}</p>
  </div>
  <p class="comparison-footer">
    Buildy · catalogue édité le {{exportDate}}
  </p>
</section>

</body>
</html>
