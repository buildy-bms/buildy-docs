{{!-- Annexe optionnelle : Decret BACS — texte integral des articles R175-1 a R175-6 --}}
<section class="bacs-annex">
  <h1 class="bacs-annex-title">Annexe — Décret BACS (R175-1 à R175-6)</h1>
  <div class="bacs-annex-intro">{{{bacsIntroHtml}}}</div>

  {{#each bacsArticles}}
  <div class="bacs-article">
    <h2 class="bacs-article-title">
      <span class="bacs-article-code">{{code}}</span>
      <span class="bacs-article-name">{{title}}</span>
    </h2>
    {{#if summary}}<p class="bacs-article-summary">{{summary}}</p>{{/if}}
    {{#if full_html}}<div class="bacs-article-body">{{{full_html}}}</div>{{/if}}
  </div>
  {{/each}}
</section>
