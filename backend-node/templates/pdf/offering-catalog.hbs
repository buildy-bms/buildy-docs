<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <title>Offres Buildy {{year}}</title>
  <style>{{{styles}}}</style>
</head>
<body>

{{!-- ═══════════ Page de garde ═══════════ --}}
<section class="cover">
  <img class="cover-logo" src="{{logoDataUrl}}" alt="Buildy" />
  <p class="cover-doc-type">Catalogue commercial</p>
  <h1 class="cover-title">Offres Buildy<br/>{{year}}</h1>
  <p class="cover-subtitle">
    Plateforme de supervision et hypervision GTB agnostique multi-sites.
    Trois niveaux de service au choix.
  </p>
  <div class="cover-stats">
    <div class="cover-stat">
      <span class="cover-stat-num">{{totalFeatures}}</span>
      <span class="cover-stat-label">Fonctionnalités</span>
    </div>
    <div class="cover-stat">
      <span class="cover-stat-num">3</span>
      <span class="cover-stat-label">Niveaux de service</span>
    </div>
  </div>
  <p class="cover-meta">Édition du {{exportDate}}</p>
</section>

{{!-- ═══════════ Tableau comparatif (1-2 pages max apres cover) ═══════════ --}}
<section class="comparison">
  <header class="comparison-head">
    <h1 class="page-title">Tableau des offres Buildy</h1>
    <div class="comparison-legend">
      <span class="legend-item"><span class="avail avail-included">✓</span> Inclus</span>
      <span class="legend-item"><span class="avail avail-option">⓪</span> Option</span>
      <span class="legend-item"><span class="avail avail-unavailable">—</span> Non dispo</span>
    </div>
  </header>

  <table class="comparison-table">
    <colgroup>
      <col class="col-feature" />
      <col class="col-level" />
      <col class="col-level" />
      <col class="col-level" />
    </colgroup>
    <thead>
      <tr>
        <th class="th-feature">Fonctionnalité</th>
        <th class="th-level th-e">
          <div class="th-level-name">Essentiel</div>
          <div class="th-level-count">{{countE}} feat.</div>
        </th>
        <th class="th-level th-s">
          <div class="th-level-name">Smart</div>
          <div class="th-level-count">{{countS}} feat.</div>
        </th>
        <th class="th-level th-p">
          <div class="th-level-name">Premium</div>
          <div class="th-level-count">{{countP}} feat.</div>
        </th>
      </tr>
    </thead>
    <tbody>
      {{#each categories}}
      <tr class="category-row">
        <td colspan="4">{{title}}</td>
      </tr>
      {{#each features}}
      <tr>
        <td class="td-feature">{{title}}</td>
        <td class="td-level"><span class="avail avail-{{avail_e}}">{{#if (eq avail_e "included")}}✓{{else}}{{#if (eq avail_e "option")}}⓪{{else}}—{{/if}}{{/if}}</span></td>
        <td class="td-level"><span class="avail avail-{{avail_s}}">{{#if (eq avail_s "included")}}✓{{else}}{{#if (eq avail_s "option")}}⓪{{else}}—{{/if}}{{/if}}</span></td>
        <td class="td-level"><span class="avail avail-{{avail_p}}">{{#if (eq avail_p "included")}}✓{{else}}{{#if (eq avail_p "option")}}⓪{{else}}—{{/if}}{{/if}}</span></td>
      </tr>
      {{/each}}
      {{/each}}
    </tbody>
  </table>

  <p class="comparison-footer">
    Buildy · {{totalFeatures}} fonctionnalités · catalogue édité le {{exportDate}}
  </p>
</section>

</body>
</html>
