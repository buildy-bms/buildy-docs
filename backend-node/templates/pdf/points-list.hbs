<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<title>Liste de points — {{af.client_name}} — {{af.project_name}}</title>
<style>{{{styles}}}</style>
</head>
<body>

{{!-- ═══════════ Page de garde ═══════════ --}}
<section class="cover">
  <div class="cover-top">
    <img class="cover-logo" src="{{logoDataUrl}}" alt="Buildy" />
    <p class="cover-doc-type">Liste de points contractuelle</p>
    <h1 class="cover-title">{{af.project_name}}</h1>
    <p class="cover-client">{{af.client_name}}</p>
    {{#if af.site_address}}<p class="cover-address">{{af.site_address}}</p>{{/if}}
  </div>

  <div class="cover-totals">
    <div class="cover-totals-item">
      <p class="cover-totals-value">{{totals.instances}}</p>
      <p class="cover-totals-label">instance{{#if (gt totals.instances 1)}}s{{/if}} d'équipement</p>
    </div>
    <div class="cover-totals-sep"></div>
    <div class="cover-totals-item">
      <p class="cover-totals-value">{{totals.points}}</p>
      <p class="cover-totals-label">point{{#if (gt totals.points 1)}}s{{/if}} de donnée attendu{{#if (gt totals.points 1)}}s{{/if}}</p>
    </div>
  </div>

  <div class="cover-meta">
    <div class="cover-meta-row">
      <span class="cover-meta-label">Version</span>
      <span class="cover-meta-value"><span class="cover-version-tag">{{version}}</span></span>
      {{#if motif}}<span class="cover-motif">{{motif}}</span>{{/if}}
    </div>
    <div class="cover-meta-row">
      <span class="cover-meta-label">Date d'export</span>
      <span class="cover-meta-value">{{exportDate}}</span>
    </div>
    <div class="cover-meta-row">
      <span class="cover-meta-label">Auteur</span>
      <span class="cover-meta-value">{{authorName}}</span>
    </div>
    <div class="cover-meta-row">
      <span class="cover-meta-label">Niveau de service</span>
      <span class="cover-meta-value">{{serviceLevelLabel}}</span>
    </div>
  </div>

  <div class="cover-bottom">
    <p class="cover-disclaimer">
      <em>Ce document liste l'ensemble des points de données attendus par instance d'équipement déclarée sur le site.
      Il fait foi pour la phase de commissionnement et l'intégration par les partenaires terrain.
      La colonne « Nom technique » impose une nomenclature commune côté intégrateur ; les écarts doivent être justifiés
      en avant-projet ou validés par Buildy avant mise en production.</em>
    </p>
    <p class="cover-legal">
      © Buildy SAS — Document confidentiel. Toute reproduction, transmission ou diffusion à des tiers, même partielle,
      est interdite sans autorisation écrite préalable.
    </p>
  </div>
</section>

{{!-- ═══════════ Tableau global de tous les points ═══════════ --}}
<section class="points-section">
  <table class="points">
    <thead>
      <tr>
        <th class="col-cat">Catégorie</th>
        <th class="col-ref">Repère</th>
        <th class="col-loc">Localisation</th>
        <th class="col-tech">Nom technique</th>
        <th class="col-label">Donnée</th>
        <th class="col-type">Type</th>
        <th class="col-dir">Sens</th>
        <th class="col-nature">Nature</th>
        <th class="col-unit">Unité</th>
        <th class="col-commentaire">Commentaire intégrateur</th>
      </tr>
    </thead>
    <tbody>
      {{#each rows}}
      <tr class="{{#if isFirstOfInstance}}row-first{{/if}}">
        <td class="col-cat">{{#if isFirstOfInstance}}{{categoryName}}{{/if}}</td>
        <td class="col-ref">{{#if isFirstOfInstance}}<strong>{{instanceRef}}</strong>{{/if}}</td>
        <td class="col-loc">{{#if isFirstOfInstance}}{{instanceLocation}}{{/if}}</td>
        <td class="col-tech">{{#if tech_name}}<code>{{tech_name}}</code>{{else}}—{{/if}}</td>
        <td class="col-label">{{label}}</td>
        <td class="col-type"><span class="badge-type type-{{data_type}}">{{data_type}}</span></td>
        <td class="col-dir"><span class="badge-dir dir-{{dirLabel}}">{{dirLabel}}</span></td>
        <td class="col-nature">{{#if nature}}<span class="badge-nature" data-nature="{{nature}}">{{nature}}</span>{{else}}—{{/if}}</td>
        <td class="col-unit">{{#if unit}}{{unit}}{{else}}—{{/if}}</td>
        <td class="col-commentaire"></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</section>

{{!-- ═══════════ Récapitulatif final ═══════════ --}}
<section class="summary">
  <h2>Récapitulatif par catégorie</h2>
  <table class="summary-table">
    <thead>
      <tr>
        <th>Catégorie d'équipement</th>
        <th class="summary-num">Instances</th>
        <th class="summary-num">Points par instance</th>
        <th class="summary-num">Total points</th>
      </tr>
    </thead>
    <tbody>
      {{#each categories}}
      <tr>
        <td>{{name}}</td>
        <td class="summary-num">{{instancesCount}}</td>
        <td class="summary-num">{{pointsPerInstance}}</td>
        <td class="summary-num">{{pointsTotal}}</td>
      </tr>
      {{/each}}
    </tbody>
    <tfoot>
      <tr>
        <td>Total général</td>
        <td class="summary-num">{{totals.instances}}</td>
        <td class="summary-num">—</td>
        <td class="summary-num">{{totals.points}}</td>
      </tr>
    </tfoot>
  </table>
</section>

</body>
</html>
