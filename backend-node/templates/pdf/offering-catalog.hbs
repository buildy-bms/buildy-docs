<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <title>Offres Buildy {{year}}</title>
  <style>{{{styles}}}</style>
</head>
<body>

{{!-- ═══════════ Page de garde ═══════════ --}}
<section class="cover">
  <img class="cover-logo" src="{{logoDataUrl}}" alt="Buildy" />
  <p class="cover-doc-type">Catalogue commercial</p>
  <h1 class="cover-title">Offres Buildy<br/>{{year}}</h1>
  <p class="cover-promise">
    Réduisez vos consommations. Anticipez les dérives.<br/>
    Conformez-vous au décret BACS — sans changer toute votre GTB.
  </p>
  <p class="cover-subtitle">
    Plateforme de supervision et hypervision GTB agnostique multi-sites.
    Trois niveaux de service. Un seul projet : votre efficacité énergétique.
  </p>
  <p class="cover-meta">Édition du {{exportDate}}</p>
</section>

{{!-- ═══════════ Tableau comparatif (1-2 pages max apres cover) ═══════════ --}}
<section class="comparison">
  <header class="comparison-head">
    <h1 class="page-title">Tableau des offres Buildy</h1>
    <div class="comparison-legend">
      <span class="legend-item"><span class="avail avail-included">✓</span> Inclus</span>
      <span class="legend-item"><span class="avail avail-option">⓪</span> Option</span>
      <span class="legend-item"><span class="avail avail-unavailable">—</span> Non dispo</span>
    </div>
  </header>

  <table class="comparison-table">
    <colgroup>
      <col class="col-feature" />
      <col class="col-level" />
      <col class="col-level" />
      <col class="col-level" />
    </colgroup>
    <thead>
      <tr>
        <th class="th-feature">Fonctionnalité</th>
        <th class="th-level th-e">
          <div class="th-level-name">Essentiel</div>
          <div class="th-level-tagline">Démarrer simple</div>
        </th>
        <th class="th-level th-s">
          <div class="th-level-badge">★ Le plus choisi</div>
          <div class="th-level-name">Smart</div>
          <div class="th-level-tagline">Pilotez et anticipez</div>
        </th>
        <th class="th-level th-p">
          <div class="th-level-name">Premium</div>
          <div class="th-level-tagline">L'intégrale</div>
        </th>
      </tr>
    </thead>
    <tbody>
      {{#each categories}}
      <tr class="category-row">
        <td colspan="4"><span class="cat-marker">▸</span> {{title}}</td>
      </tr>
      {{#each features}}
      <tr>
        <td class="td-feature">{{title}}</td>
        <td class="td-level td-level-e"><span class="avail avail-{{avail_e}}">{{#if (eq avail_e "included")}}✓{{else}}{{#if (eq avail_e "option")}}⓪{{else}}—{{/if}}{{/if}}</span></td>
        <td class="td-level td-level-s"><span class="avail avail-{{avail_s}}">{{#if (eq avail_s "included")}}✓{{else}}{{#if (eq avail_s "option")}}⓪{{else}}—{{/if}}{{/if}}</span></td>
        <td class="td-level td-level-p"><span class="avail avail-{{avail_p}}">{{#if (eq avail_p "included")}}✓{{else}}{{#if (eq avail_p "option")}}⓪{{else}}—{{/if}}{{/if}}</span></td>
      </tr>
      {{/each}}
      {{/each}}
    </tbody>
  </table>

  <div class="cta-block">
    <p class="cta-line">Prêt à démarrer ?</p>
    <p class="cta-sub">Notre équipe revient vers vous sous 48 h ouvrées.</p>
    <p class="cta-contact">contact@buildy.fr · 01 23 45 67 89</p>
  </div>
  <p class="comparison-footer">
    Buildy · catalogue édité le {{exportDate}}
  </p>
</section>

</body>
</html>
