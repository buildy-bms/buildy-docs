{{!-- Partial recursif pour rendre une section + ses enfants. --}}
{{!-- Le niveau (depth) determine la balise H : depth=0 → h1, depth=1 → h2, etc. --}}

<div class="section depth-{{depth}}" data-toc-anchor="sec-{{id}}" id="sec-{{id}}">
  {{#if (eq depth 0)}}
    <h1>
      <span class="section-num">{{number}}</span>{{title}}
      <span class="section-badges">
        {{#if service_level_label}}<span class="badge-level {{badgeClass}}">{{service_level_label}}</span>{{/if}}
        {{!-- Badge BACS retiré du header — désormais dans l'encart .bacs-context juste sous le titre --}}
      </span>
    </h1>
  {{else if (eq depth 1)}}
    <h2>
      <span class="section-num">{{number}}</span>{{title}}
      <span class="section-badges">
        {{#if service_level_label}}<span class="badge-level {{badgeClass}}">{{service_level_label}}</span>{{/if}}
        {{!-- Badge BACS retiré du header — désormais dans l'encart .bacs-context juste sous le titre --}}
      </span>
    </h2>
  {{else if (eq depth 2)}}
    <h3>
      <span class="section-num">{{number}}</span>{{title}}
      <span class="section-badges">
        {{#if service_level_label}}<span class="badge-level {{badgeClass}}">{{service_level_label}}</span>{{/if}}
        {{!-- Badge BACS retiré du header — désormais dans l'encart .bacs-context juste sous le titre --}}
      </span>
    </h3>
  {{else}}
    <h4>
      <span class="section-num">{{number}}</span>{{title}}
      <span class="section-badges">
        {{#if service_level_label}}<span class="badge-level {{badgeClass}}">{{service_level_label}}</span>{{/if}}
        {{!-- Badge BACS retiré du header — désormais dans l'encart .bacs-context juste sous le titre --}}
      </span>
    </h4>
  {{/if}}

  {{!-- Disclaimer générique retiré (Lot 14.3) — désormais affiché une seule fois en page de garde --}}

  {{!-- Encart contextualisé "lien avec le décret BACS" (Lot 17b) --}}
  {{#if bacs_articles_label}}
  <div class="bacs-context">
    <p class="bacs-context-label">⚖️ {{bacs_articles_label}}</p>
    {{#if bacs_justification}}
    <p class="bacs-context-text">{{bacs_justification}}</p>
    {{/if}}
  </div>
  {{/if}}

  {{#if body_html}}
  <div class="section-body">{{{body_html}}}</div>
  {{/if}}

  {{#if synthesis_table_html}}
  <div class="section-body">{{{synthesis_table_html}}}</div>
  {{/if}}

  {{#if zones.length}}
  <div class="zones-block">
    <table class="zones-table">
      <thead>
        <tr>
          <th>Zone</th>
          <th class="num">Surface</th>
          <th>Type</th>
          <th class="num">Pers. max</th>
          <th>Horaires</th>
          <th>Contraintes / notes</th>
        </tr>
      </thead>
      <tbody>
        {{#each zones}}
        <tr>
          <td class="zone-name">{{name}}</td>
          <td class="num">{{#if surface_m2}}{{surface_m2}} m²{{else}}—{{/if}}</td>
          <td>{{#if occupation_type}}{{occupation_type}}{{else}}—{{/if}}</td>
          <td class="num">{{#if occupation_max_personnes}}{{occupation_max_personnes}}{{else}}—{{/if}}</td>
          <td>{{#if horaires}}{{horaires}}{{else}}—{{/if}}</td>
          <td>{{#if qai_contraintes}}{{qai_contraintes}}{{else}}{{notes}}{{/if}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  {{#if equipment}}
    {{#if equipment.description_html}}
    <div class="section-body">{{{equipment.description_html}}}</div>
    {{/if}}

    {{#if equipment.preferred_protocols.length}}
    <p class="protocols-bar">
      <span class="protocols-label">Protocoles exigés :</span>
      {{#each equipment.preferred_protocols}}
      <span class="protocol-pill">{{this}}</span>
      {{/each}}
    </p>
    {{/if}}

    {{#if equipment.points_read.length}}
    <div class="points-block">
      <h5 class="points-block-title">Données typiquement lues ({{equipment.points_read.length}})</h5>
      <table class="points-mini">
        <thead><tr><th>Donnée</th><th>Nom technique</th><th>Type</th><th>Nature</th><th>Unité</th></tr></thead>
        <tbody>
          {{#each equipment.points_read}}
          <tr>
            <td>{{label}}</td>
            <td class="tech-name">{{#if tech_name}}<code>{{tech_name}}</code>{{else}}—{{/if}}</td>
            <td><span class="badge-type type-{{data_type}}">{{data_type}}</span></td>
            <td class="nature">{{#if nature}}{{nature}}{{else}}—{{/if}}</td>
            <td>{{#if unit}}{{unit}}{{else}}—{{/if}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{/if}}
    {{#if equipment.points_write.length}}
    <div class="points-block">
      <h5 class="points-block-title">Données typiquement écrites ({{equipment.points_write.length}})</h5>
      <table class="points-mini">
        <thead><tr><th>Donnée</th><th>Nom technique</th><th>Type</th><th>Nature</th><th>Unité</th></tr></thead>
        <tbody>
          {{#each equipment.points_write}}
          <tr>
            <td>{{label}}</td>
            <td class="tech-name">{{#if tech_name}}<code>{{tech_name}}</code>{{else}}—{{/if}}</td>
            <td><span class="badge-type type-{{data_type}}">{{data_type}}</span></td>
            <td class="nature">{{#if nature}}{{nature}}{{else}}—{{/if}}</td>
            <td>{{#if unit}}{{unit}}{{else}}—{{/if}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{/if}}
  {{/if}}

  {{#if attachments.length}}
  <div class="captures">
    <h5 class="captures-title">Captures ({{attachments.length}})</h5>
    {{#each attachments}}
    <div class="capture">
      <img src="{{dataUrl}}" alt="{{caption}}" />
      {{#if caption}}<p class="capture-caption">{{caption}}</p>{{/if}}
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#each children}}
    {{> _section this}}
  {{/each}}
</div>
